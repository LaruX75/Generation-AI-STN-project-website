{
  "name": "generation-ai-stn-fi",
  "private": true,
  "scripts": {
    "predev": "node scripts/normalize-localized-frontmatter.js",
    "dev": "npm run dev:offline",
    "dev:offline": "node scripts/run-with-data-mode.js offline ./node_modules/.bin/eleventy --serve",
    "dev:live": "node scripts/run-with-data-mode.js live ./node_modules/.bin/eleventy --serve",
    "prebuild": "node scripts/normalize-localized-frontmatter.js && node scripts/clean-output.js",
    "build": "npm run build:offline",
    "build:offline": "node scripts/run-with-data-mode.js offline ./node_modules/.bin/eleventy",
    "build:live": "node scripts/run-with-data-mode.js live ./node_modules/.bin/eleventy",
    "build:test": "node scripts/normalize-localized-frontmatter.js && node scripts/clean-output.js _site_playwright && ELEVENTY_OUTPUT_DIR=_site_playwright node scripts/run-with-data-mode.js offline ./node_modules/.bin/eleventy",
    "data:refresh": "node scripts/refresh-data-cache.js",
    "search:index": "node scripts/run-pagefind.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "translate": "node scripts/translate-content.js",
    "translate:all": "node scripts/translate-content.js --all",
    "translations:check": "node scripts/check-translations.js"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@uncenter/eleventy-plugin-toc": "^2.0.0",
    "gridjs": "^6.2.0",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "pagefind": "^1.4.0",
    "playwright-core": "^1.58.2"
  }
}
