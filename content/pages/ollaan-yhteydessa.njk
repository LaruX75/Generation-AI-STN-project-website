<script>
(function () {
  var form = document.getElementById('contact-form-fi');
  var status = document.getElementById('contact-status-fi');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Lähetetään…';
    fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success) {
          form.reset();
          status.textContent = 'Kiitos viestistäsi! Vastaamme mahdollisimman pian.';
          status.className = 'contact-form-status contact-form-status--ok';
        } else {
          status.textContent = 'Lähetys epäonnistui. Yritä uudelleen tai lähetä sähköpostia osoitteeseen info@generation-ai-stn.fi';
          status.className = 'contact-form-status contact-form-status--err';
          btn.disabled = false;
          btn.textContent = 'Lähetä viesti';
        }
        status.hidden = false;
      })
      .catch(function () {
        status.textContent = 'Verkkovirhe. Lähetä sähköpostia osoitteeseen info@generation-ai-stn.fi';
        status.className = 'contact-form-status contact-form-status--err';
        status.hidden = false;
        btn.disabled = false;
        btn.textContent = 'Lähetä viesti';
      });
  });
}());
</script>

