{# ── Ajankohtaista — vaalea vihreä ───────────────────────────────────────── #}
{% set mediaItems     = collections["media"]            | localizedItems(lang, page.url) %}
{% set tapahtumaItems = collections["tapahtumat"]       | localizedItems(lang, page.url) %}
{% set toimintaItems  = collections["hankkeen-toiminta"]| localizedItems(lang, page.url) %}
{% set tutkimusItems  = collections["tutkimus"]         | localizedItems(lang, page.url) %}

<section class="toiminta-digest">
  <div class="toiminta-digest-inner">
    <h2 class="toiminta-digest-heading">Ajankohtaista</h2>
    <div class="toiminta-digest-grid">

      <div class="toiminta-digest-col">
        <h3 class="toiminta-digest-col-heading">Uutiset ja media</h3>
        <ul class="toiminta-digest-list">
          {% for item in mediaItems | limitItems(3) %}
          <li class="toiminta-digest-item">
            <a href="{{ item.url }}">{{ item.data.title }}</a>
            <span class="toiminta-digest-date">{{ item.date | date("d.m.Y") }}</span>
          </li>
          {% else %}
          <li class="toiminta-digest-empty">Ei sisältöjä.</li>
          {% endfor %}
        </ul>
        <a class="toiminta-digest-cta" href="/ajankohtaista/#tab-media">Kaikki uutiset →</a>
      </div>

      <div class="toiminta-digest-col">
        <h3 class="toiminta-digest-col-heading">Tapahtumat</h3>
        <ul class="toiminta-digest-list">
          {% for item in tapahtumaItems | limitItems(3) %}
          <li class="toiminta-digest-item">
            <a href="{{ item.url }}">{{ item.data.title }}</a>
            <span class="toiminta-digest-date">{{ item.date | date("d.m.Y") }}</span>
          </li>
          {% else %}
          <li class="toiminta-digest-empty">Ei sisältöjä.</li>
          {% endfor %}
        </ul>
        <a class="toiminta-digest-cta" href="/ajankohtaista/#tab-tapahtumat">Kaikki tapahtumat →</a>
      </div>

      <div class="toiminta-digest-col">
        <h3 class="toiminta-digest-col-heading">Hankkeen toiminta</h3>
        <ul class="toiminta-digest-list">
          {% for item in toimintaItems | limitItems(3) %}
          <li class="toiminta-digest-item">
            <a href="{{ item.url }}">{{ item.data.title }}</a>
            <span class="toiminta-digest-date">{{ item.date | date("d.m.Y") }}</span>
          </li>
          {% else %}
          <li class="toiminta-digest-empty">Ei sisältöjä.</li>
          {% endfor %}
        </ul>
        <a class="toiminta-digest-cta" href="/ajankohtaista/#tab-toiminta">Kaikki toiminta →</a>
      </div>

      <div class="toiminta-digest-col">
        <h3 class="toiminta-digest-col-heading">Konferenssit ja julkaisut</h3>
        <ul class="toiminta-digest-list">
          {% set mergedPubs = tutkimusItems | mergeConferencesAndPubs(scientificPublications.tableItems, 4) %}
          {% for card in mergedPubs %}
          <li class="toiminta-digest-item">
            {% if card.cardType == "conference" %}
              <a href="{{ card.item.url }}">{{ card.item.data.title }}</a>
              <span class="toiminta-digest-date">{{ card.item.date | date("d.m.Y") }}</span>
            {% else %}
              {% if card.item.link %}
              <a href="{{ card.item.link }}" target="_blank" rel="noopener" class="toiminta-digest-citation">{{ card.item.citation }}</a>
              {% else %}
              <span class="toiminta-digest-citation">{{ card.item.citation }}</span>
              {% endif %}
              <span class="toiminta-digest-date">{{ card.item.year }}</span>
            {% endif %}
          </li>
          {% else %}
          <li class="toiminta-digest-empty">Ei sisältöjä.</li>
          {% endfor %}
        </ul>
        <a class="toiminta-digest-cta" href="/ajankohtaista/#tab-tutkimus">Kaikki julkaisut →</a>
      </div>

    </div>
  </div>
</section>
