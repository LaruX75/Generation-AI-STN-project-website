{% set totalPeople = workPackageLeaders.concat(consortiumMembers) %}

<div class="konsortio-page">

  <p class="konsortio-section__lead">Generation AI on monitieteinen tutkimuskonsortio, jossa yhdistyvät kasvatustieteen, tietojenkäsittelytieteen ja oikeustieteen asiantuntijuus. Hankkeessa on mukana tutkijoita neljästä organisaatiosta: Helsingin yliopistosta, Itä-Suomen yliopistosta (UEF), Oulun yliopistosta ja Suomen koodikoulusta.</p>

  <div class="consortium-filters" data-consortium-filters>
    <div class="consortium-filters__controls">
      <div class="consortium-filters__field">
        <label for="consortium-filter-organization">Organisaatio</label>
        <select id="consortium-filter-organization" data-filter-organization>
          <option value="">Kaikki organisaatiot</option>
          <option value="Helsingin yliopisto">Helsingin yliopisto</option>
          <option value="Itä-Suomen yliopisto (UEF)">Itä-Suomen yliopisto (UEF)</option>
          <option value="Oulun yliopisto">Oulun yliopisto</option>
          <option value="Suomen koodikoulu (Codeschool Finland)">Suomen koodikoulu (Codeschool Finland)</option>
        </select>
      </div>
      <div class="consortium-filters__field">
        <label for="consortium-filter-discipline">Tieteenala</label>
        <select id="consortium-filter-discipline" data-filter-discipline>
          <option value="">Kaikki tieteenalat</option>
          <option value="Kasvatustiede">Kasvatustiede</option>
          <option value="Tietojenkäsittelytiede">Tietojenkäsittelytiede</option>
          <option value="Oikeustiede">Oikeustiede</option>
        </select>
      </div>
    </div>
    <p class="consortium-filters__status" data-filter-status>Näytetään {{ totalPeople.length }} henkilöä.</p>
  </div>

  <section data-consortium-section>
    <h2 class="consortium-group-title">Hankkeen johto</h2>
    <div class="consortium-grid">
      {% for person in workPackageLeaders %}
        {{ renderPersonCard(person, true) }}
      {% endfor %}
    </div>
  </section>

  <section data-consortium-section>
    <h2 class="consortium-group-title">Konsortion jäsenet</h2>
    <div class="consortium-grid">
      {% for person in consortiumMembers %}
        {{ renderPersonCard(person) }}
      {% endfor %}
    </div>
  </section>

  <section>
    <h2 class="consortium-group-title">Yhteistyökumppanit</h2>
    <div class="consortium-grid">
      {% for partner in partners %}
        {{ renderPersonCard(partner) }}
      {% endfor %}
    </div>
  </section>

</div>

<script>
(function () {
  var orgSel  = document.querySelector('[data-filter-organization]');
  var discSel = document.querySelector('[data-filter-discipline]');
  var status  = document.querySelector('[data-filter-status]');
  if (!orgSel || !discSel || !status) return;

  var cards    = Array.prototype.slice.call(document.querySelectorAll('[data-card]'));
  var sections = Array.prototype.slice.call(document.querySelectorAll('[data-consortium-section]'));

  function normalize(v) { return String(v || '').trim().toLowerCase(); }

  function applyFilters() {
    var org  = normalize(orgSel.value);
    var disc = normalize(discSel.value);
    var count = 0;

    cards.forEach(function (card) {
      var show = (!org  || normalize(card.dataset.organization) === org) &&
                 (!disc || normalize(card.dataset.discipline)   === disc);
      card.hidden = !show;
      if (show) count++;
    });

    sections.forEach(function (section) {
      var any = Array.prototype.some.call(
        section.querySelectorAll('[data-card]'),
        function (c) { return !c.hidden; }
      );
      section.hidden = !any;
    });

    status.textContent = 'Näytetään ' + count + ' henkilöä.';
  }

  orgSel.addEventListener('change', applyFilters);
  discSel.addEventListener('change', applyFilters);
  applyFilters();
})();

// Publication title truncation
(function () {
  requestAnimationFrame(function () {
    document.querySelectorAll('.researchfi-card__name').forEach(function (el) {
      if (el.scrollHeight > el.clientHeight + 2) {
        var btn = el.nextElementSibling;
        if (btn && btn.classList.contains('researchfi-card__expand-btn')) {
          btn.classList.add('is-visible');
          btn.addEventListener('click', function () {
            el.classList.toggle('is-expanded');
            btn.textContent = el.classList.contains('is-expanded') ? 'Vähemmän' : 'Lisää';
          });
        }
      }
    });
  });
})();
</script>
