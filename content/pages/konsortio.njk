<style>
  .konsortio-page {
    display: grid;
    gap: 3rem;
  }

  .konsortio-section {
    display: grid;
    gap: 1.5rem;
  }

  .konsortio-section__header {
    display: grid;
    gap: 0.75rem;
  }

  .konsortio-section__lead {
    max-width: 74ch;
    margin: 0;
    color: #475569;
  }

  .consortium-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    align-items: stretch;
  }

  .consortium-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 4.5rem 1.25rem 1.25rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 1rem;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbf7 100%);
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
  }

  .consortium-card--featured {
    background: linear-gradient(180deg, #ffffff 0%, #f4f8f1 100%);
    border-color: rgba(49, 78, 37, 0.16);
  }

  .consortium-card__meta-row {
    position: absolute;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    pointer-events: none;
  }

  .consortium-card__meta {
    display: inline-flex;
    align-items: center;
    max-width: 48%;
    padding: 0.32rem 0.65rem;
    border-radius: 999px;
    background: #eef4ea;
    color: #314e25;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .consortium-card__meta--discipline {
    margin-left: auto;
    background: #f3f4f6;
    color: #334155;
    text-align: right;
    justify-content: flex-end;
  }

  .consortium-card__image {
    width: 104px;
    height: 104px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    object-fit: cover;
    background: #e5e7eb;
  }

  .consortium-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  .consortium-card__name {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.2;
    text-align: center;
  }

  .consortium-card__role {
    margin: 0.45rem 0 0;
    color: #334155;
    font-weight: 600;
    text-align: center;
  }

  .consortium-card__description,
  .consortium-card__contact,
  .consortium-card__actions {
    margin: 0.85rem 0 0;
    color: #475569;
    line-height: 1.55;
  }

  .consortium-card__contact,
  .consortium-card__actions {
    text-align: center;
  }

  .consortium-card__actions a,
  .consortium-card__contact a {
    color: var(--global-palette2, #446d33);
    text-decoration: none;
  }

  .consortium-card__actions a:hover,
  .consortium-card__contact a:hover {
    text-decoration: underline;
  }

  .consortium-filters {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 1rem;
    background: #f8fafc;
  }

  .consortium-filters__controls {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .consortium-filters__field {
    display: grid;
    gap: 0.35rem;
  }

  .consortium-filters__field label {
    font-size: 0.82rem;
    font-weight: 700;
    color: #334155;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .consortium-filters__field select {
    width: 100%;
    min-height: 44px;
    padding: 0.7rem 0.85rem;
    border: 1px solid rgba(148, 163, 184, 0.55);
    border-radius: 0.75rem;
    background: #fff;
    color: #0f172a;
    font: inherit;
  }

  .consortium-filters__status {
    margin: 0;
    color: #475569;
    font-size: 0.95rem;
  }

  .researchfi-card {
    margin-top: auto;
    padding-top: 1rem;
  }

  .researchfi-card__title {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    line-height: 1.3;
  }

  .researchfi-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
