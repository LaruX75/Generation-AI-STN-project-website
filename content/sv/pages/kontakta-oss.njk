<section class="contact-page">
  <div class="contact-page-inner">

    <div class="contact-info">
      <p class="contact-lead">Vill du veta mer om projektet, föreslå ett samarbete eller komma i kontakt med forskarteamet? Skicka oss ett meddelande — vi svarar så snart som möjligt.</p>

      <ul class="contact-details">
        <li>
          <span class="contact-detail-label">E-post</span>
          <a href="mailto:info@generation-ai-stn.fi">info@generation-ai-stn.fi</a>
        </li>
        <li>
          <span class="contact-detail-label">Projekt</span>
          Generation AI — AI-utbildning för framtidens generation
        </li>
      </ul>
    </div>

    <div class="contact-form-wrap">
      <form class="contact-form" id="contact-form-sv" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="e7668089-af89-471f-b97a-42bdfbc92f57">
        <input type="hidden" name="subject" value="Kontakt — Generation AI">
        <input type="hidden" name="from_name" value="Generation AI webbplats">
        <input type="checkbox" name="botcheck" style="display:none">
        <div class="contact-form-field">
          <label for="cf-name-sv">Namn</label>
          <input id="cf-name-sv" type="text" name="name" required placeholder="Förnamn Efternamn">
        </div>
        <div class="contact-form-field">
          <label for="cf-email-sv">E-post</label>
          <input id="cf-email-sv" type="email" name="email" required placeholder="du@exempel.fi">
        </div>
        <div class="contact-form-field">
          <label for="cf-topic-sv">Ämne</label>
          <input id="cf-topic-sv" type="text" name="topic" placeholder="Vad handlar det om?">
        </div>
        <div class="contact-form-field">
          <label for="cf-message-sv">Meddelande</label>
          <textarea id="cf-message-sv" name="message" rows="5" required placeholder="Skriv ditt meddelande här…"></textarea>
        </div>
        <button class="contact-form-btn" type="submit">Skicka meddelande</button>
        <p class="contact-form-status" id="contact-status-sv" aria-live="polite" hidden></p>
      </form>
    </div>
<script>
(function () {
  var form = document.getElementById('contact-form-sv');
  var status = document.getElementById('contact-status-sv');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Skickar…';
    fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success) {
          form.reset();
          status.textContent = 'Tack! Vi återkommer så snart som möjligt.';
          status.className = 'contact-form-status contact-form-status--ok';
        } else {
          status.textContent = 'Misslyckades. Försök igen eller skicka e-post till info@generation-ai-stn.fi';
          status.className = 'contact-form-status contact-form-status--err';
          btn.disabled = false;
          btn.textContent = 'Skicka meddelande';
        }
        status.hidden = false;
      })
      .catch(function () {
        status.textContent = 'Nätverksfel. Skicka e-post till info@generation-ai-stn.fi';
        status.className = 'contact-form-status contact-form-status--err';
        status.hidden = false;
        btn.disabled = false;
        btn.textContent = 'Skicka meddelande';
      });
  });
}());
</script>

  </div>
</section>
