<div class="konsortio-page">

  <p class="konsortio-section__lead">Generation AI är ett tvärvetenskapligt forskningskonsortium som kombinerar expertis inom pedagogik, datavetenskap och juridik. Projektet samlar forskare från fyra organisationer: Helsingfors universitet, Östra Finlands universitet (UEF), Uleåborgs universitet och Finlands kodskola.</p>

  <div class="consortium-filters" data-consortium-filters>
    <div class="consortium-filters__controls">
      <div class="consortium-filters__field">
        <label for="consortium-filter-organization">Organisation</label>
        <select id="consortium-filter-organization" data-filter-organization>
          <option value="">Alla organisationer</option>
          <option value="Helsingfors universitet">Helsingfors universitet</option>
          <option value="Östra Finlands universitet (UEF)">Östra Finlands universitet (UEF)</option>
          <option value="Uleåborgs universitet">Uleåborgs universitet</option>
          <option value="Finlands kodskola (Codeschool Finland)">Finlands kodskola (Codeschool Finland)</option>
        </select>
      </div>
      <div class="consortium-filters__field">
        <label for="consortium-filter-discipline">Vetenskaplig disciplin</label>
        <select id="consortium-filter-discipline" data-filter-discipline>
          <option value="">Alla discipliner</option>
          <option value="Pedagogik">Pedagogik</option>
          <option value="Datavetenskap">Datavetenskap</option>
          <option value="Juridik">Juridik</option>
        </select>
      </div>
    </div>
    <p class="consortium-filters__status" data-filter-status>Visar {{ totalPeople.length }} personer.</p>
  </div>

  <section data-consortium-section>
    <h2 class="consortium-group-title">Projektledning</h2>
    <div class="consortium-grid">
      {% for person in workPackageLeaders %}
        {{ renderPersonCard(person, true) }}
      {% endfor %}
    </div>
  </section>

  <section data-consortium-section>
    <h2 class="consortium-group-title">Konsortiummedlemmar</h2>
    <div class="consortium-grid">
      {% for person in consortiumMembers %}
        {{ renderPersonCard(person) }}
      {% endfor %}
    </div>
  </section>

  <section>
    <h2 class="consortium-group-title">Samarbetspartners</h2>
    <div class="consortium-grid">
      {% for partner in partners %}
        {{ renderPersonCard(partner) }}
      {% endfor %}
    </div>
  </section>

</div>

<script>
(function () {
  var orgSel  = document.querySelector('[data-filter-organization]');
  var discSel = document.querySelector('[data-filter-discipline]');
  var status  = document.querySelector('[data-filter-status]');
  if (!orgSel || !discSel || !status) return;

  var cards    = Array.prototype.slice.call(document.querySelectorAll('[data-card]'));
  var sections = Array.prototype.slice.call(document.querySelectorAll('[data-consortium-section]'));

  function normalize(v) { return String(v || '').trim().toLowerCase(); }

  function applyFilters() {
    var org  = normalize(orgSel.value);
    var disc = normalize(discSel.value);
    var count = 0;

    cards.forEach(function (card) {
      var show = (!org  || normalize(card.dataset.organization) === org) &&
                 (!disc || normalize(card.dataset.discipline)   === disc);
      card.hidden = !show;
      if (show) count++;
    });

    sections.forEach(function (section) {
      var any = Array.prototype.some.call(
        section.querySelectorAll('[data-card]'),
        function (c) { return !c.hidden; }
      );
      section.hidden = !any;
    });

    status.textContent = 'Visar ' + count + ' personer.';
  }

  orgSel.addEventListener('change', applyFilters);
  discSel.addEventListener('change', applyFilters);
  applyFilters();
})();

// Publication title truncation
(function () {
  requestAnimationFrame(function () {
    document.querySelectorAll('.researchfi-card__name').forEach(function (el) {
      if (el.scrollHeight > el.clientHeight + 2) {
        var btn = el.nextElementSibling;
        if (btn && btn.classList.contains('researchfi-card__expand-btn')) {
          btn.classList.add('is-visible');
          btn.addEventListener('click', function () {
            el.classList.toggle('is-expanded');
            btn.textContent = el.classList.contains('is-expanded') ? 'Mindre' : 'Mer';
          });
        }
      }
    });
  });
})();
</script>
