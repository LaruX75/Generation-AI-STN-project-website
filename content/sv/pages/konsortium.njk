{% macro renderResearchfiCard(personName) %}
{% set publications = researchfi | publicationsForPerson(personName) %}
{% if not publications.length %}
{% set publications = scholarlyPublications | publicationsForPerson(personName) %}
{% endif %}
{% if not publications.length %}
{% set publications = scientificPublications.items | publicationsForPerson(personName) %}
{% endif %}
{% set first = publications[0] if publications.length else null %}
{% set profileUrl = first.personId if (first and first.personId and (first.personId | isHttpUrl)) else (first.link if (first and first.link) else "") %}
<div class="researchfi-card">
  <h5 class="researchfi-card__title">Senaste publikation</h5>
  {% if first %}
  <ul class="researchfi-card__list">
    <li class="researchfi-card__item">
      <div class="researchfi-card__meta">{{ first.year }}{% if first.place or first.venue %} · {{ first.place or first.venue }}{% endif %}</div>
      <strong class="researchfi-card__name">{{ first.title }}</strong>
      <button class="researchfi-card__expand-btn" type="button" aria-label="Visa hela titeln">Mer</button>
      {% if first.authors or first.authorsText %}
      <div class="researchfi-card__authors">{{ first.authors or first.authorsText }}</div>
      {% endif %}
    </li>
  </ul>
  {% if profileUrl %}
  <a href="{{ profileUrl }}" class="researchfi-card__all-link" target="_blank" rel="noopener">Alla publikationer →</a>
  {% endif %}
  {% else %}
  <p class="researchfi-card__empty">Inga publikationer i offentliga forskningsprofiler.</p>
  {% endif %}
</div>
{% endmacro %}

{% macro renderOrgContent(partner) %}
{% if partner.featuredContent and partner.featuredContent.length %}
<div class="researchfi-card">
  <h5 class="researchfi-card__title">Aktuellt</h5>
  <ul class="researchfi-card__list">
    {% for item in partner.featuredContent %}
    <li class="researchfi-card__item">
      <div class="researchfi-card__meta">{{ item.date }}</div>
      <strong class="researchfi-card__name"><a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a></strong>
    </li>
    {% endfor %}
  </ul>
</div>
{% endif %}
{% endmacro %}

{% macro renderPersonCard(person, featured = false) %}
{% set resolvedImageUrl = person.imageUrl | resolveSiteMediaUrl %}
<article
  class="consortium-card{% if featured %} consortium-card--featured{% endif %}"
  {% if not person.isOrgCard %}data-card{% endif %}
  data-name="{{ person.name }}"
  data-organization="{{ person.organization }}"
  data-discipline="{{ person.discipline }}"
>
  {% if resolvedImageUrl %}
  <img class="consortium-card__image{% if person.isOrgCard %} consortium-card__image--org{% endif %}" src="{{ resolvedImageUrl }}" alt="{{ person.name }}" loading="lazy" />
  {% elif person.isOrgCard %}
  <div class="consortium-card__org-placeholder">{{ person.orgInitials if person.orgInitials else person.name[0] }}</div>
  {% else %}
  <div class="consortium-card__person-placeholder">{{ person.name | initials }}</div>
  {% endif %}

  <div class="consortium-card__body">
    <h3 class="consortium-card__name">{{ person.name }}</h3>
    {% if person.role %}
    <p class="consortium-card__role">{{ person.role }}</p>
    {% endif %}
    <div class="consortium-card__meta-row">
      <span class="consortium-card__meta consortium-card__meta--org">{{ person.organization }}</span>
      {% if person.discipline %}
      <span class="consortium-card__meta consortium-card__meta--discipline">{{ person.discipline }}</span>
      {% endif %}
    </div>
    {% if person.description %}
    <p class="consortium-card__description">{{ person.description }}</p>
    {% endif %}
    <div class="consortium-card__links">
      {% if person.email %}
      <a class="consortium-card__email" href="mailto:{{ person.email }}">{{ person.email }}</a>
      {% endif %}
      {% if person.profileUrl or person.orcidUrl %}
      <div class="consortium-card__profile-links">
        {% if person.profileUrl %}
        <a href="{{ person.profileUrl }}" class="consortium-card__profile-link" target="_blank" rel="noopener noreferrer">{% if "uefconnect" in person.profileUrl %}UEF Connect{% elif "researchportal.helsinki" in person.profileUrl %}Research Portal{% elif "oulu.fi/en/researchers" in person.profileUrl %}OuluCris{% elif "linkedin.com" in person.profileUrl %}LinkedIn{% else %}Profil{% endif %}<span class="sr-only"> (öppnas i ny flik)</span></a>
        {% endif %}
        {% if person.orcidUrl %}
        <a href="{{ person.orcidUrl }}" class="consortium-card__profile-link consortium-card__profile-link--orcid" target="_blank" rel="noopener">ORCID</a>
        {% endif %}
      </div>
      {% endif %}
    </div>
    {% if person.isOrgCard %}
      {{ renderOrgContent(person) }}
    {% else %}
      {{ renderResearchfiCard(person.publicationName or person.name) }}
    {% endif %}
  </div>
</article>
{% endmacro %}

