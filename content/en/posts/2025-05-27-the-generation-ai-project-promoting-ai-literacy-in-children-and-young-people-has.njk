} %}
{% set _kb_save_4 = kadenceBlock %}
{% set kadenceInnerHtml %}
<br><strong>The award is the project's third award within a year; previous awards came from conferences IEEE ICALT 2024 and AACE EdMedia 2025.</strong>
{% endset %}
