<section class="contact-page">
  <div class="contact-page-inner">

    <div class="contact-info">
      <p class="contact-lead">Want to learn more about the project, propose a collaboration or reach the research team? Send us a message — we will get back to you as soon as possible.</p>

      <ul class="contact-details">
        <li>
          <span class="contact-detail-label">Email</span>
          <a href="mailto:info@generation-ai-stn.fi">info@generation-ai-stn.fi</a>
        </li>
        <li>
          <span class="contact-detail-label">Project</span>
          Generation AI — AI Education for the Future Generation
        </li>
      </ul>
    </div>

    <div class="contact-form-wrap">
      <form class="contact-form" id="contact-form-en" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="e7668089-af89-471f-b97a-42bdfbc92f57">
        <input type="hidden" name="subject" value="Contact — Generation AI">
        <input type="hidden" name="from_name" value="Generation AI website">
        <input type="checkbox" name="botcheck" style="display:none">
        <div class="contact-form-field">
          <label for="cf-name-en">Name</label>
          <input id="cf-name-en" type="text" name="name" required placeholder="First Last">
        </div>
        <div class="contact-form-field">
          <label for="cf-email-en">Email</label>
          <input id="cf-email-en" type="email" name="email" required placeholder="you@example.com">
        </div>
        <div class="contact-form-field">
          <label for="cf-topic-en">Subject</label>
          <input id="cf-topic-en" type="text" name="topic" placeholder="What is this about?">
        </div>
        <div class="contact-form-field">
          <label for="cf-message-en">Message</label>
          <textarea id="cf-message-en" name="message" rows="5" required placeholder="Write your message here…"></textarea>
        </div>
        <button class="contact-form-btn" type="submit">Send message</button>
        <p class="contact-form-status" id="contact-status-en" aria-live="polite" hidden></p>
      </form>
    </div>
<script>
(function () {
  var form = document.getElementById('contact-form-en');
  var status = document.getElementById('contact-status-en');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Sending…';
    fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success) {
          form.reset();
          status.textContent = 'Thank you! We will get back to you as soon as possible.';
          status.className = 'contact-form-status contact-form-status--ok';
        } else {
          status.textContent = 'Submission failed. Please try again or email info@generation-ai-stn.fi';
          status.className = 'contact-form-status contact-form-status--err';
          btn.disabled = false;
          btn.textContent = 'Send message';
        }
        status.hidden = false;
      })
      .catch(function () {
        status.textContent = 'Network error. Please email info@generation-ai-stn.fi';
        status.className = 'contact-form-status contact-form-status--err';
        status.hidden = false;
        btn.disabled = false;
        btn.textContent = 'Send message';
      });
  });
}());
</script>

  </div>
</section>
