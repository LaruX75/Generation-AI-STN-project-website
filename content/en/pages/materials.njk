{# ── BetterDocs Materials ─────────────────────────────────────────────── #}
{% if collections.docs_by_kb %}
<section class="docs-index">
  {% for kb, kbDocs in collections.docs_by_kb %}
  <div class="docs-kb-section">
    <h2 class="docs-kb-title">{{ kb }}</h2>
    <ul class="docs-list">
      {% for doc in kbDocs %}
      <li class="docs-list-item">
        <a href="{{ doc.url }}">{{ doc.data.title }}</a>
        {% if doc.data["doc-category"] and doc.data["doc-category"][0] %}
          <span class="docs-cat">{{ doc.data["doc-category"][0] }}</span>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</section>
{% endif %}