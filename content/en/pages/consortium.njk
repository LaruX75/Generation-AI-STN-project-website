<div class="konsortio-page">
  <section class="konsortio-section">
    <div class="konsortio-section__header">
      <h1>Consortium</h1>
      <p class="konsortio-section__lead">
        Work package leaders appear first in the list. Other consortium members follow in alphabetical order.
      </p>
    </div>

    <div class="consortium-filters" data-consortium-filters>
      <div class="consortium-filters__controls">
        <div class="consortium-filters__field">
          <label for="consortium-filter-organization">Organization</label>
          <select id="consortium-filter-organization" data-filter-organization>
            <option value="">All organizations</option>
            <option value="University of Helsinki">University of Helsinki</option>
            <option value="University of Eastern Finland (UEF)">University of Eastern Finland (UEF)</option>
            <option value="University of Oulu">University of Oulu</option>
            <option value="Codeschool Finland">Codeschool Finland</option>
          </select>
        </div>

        <div class="consortium-filters__field">
          <label for="consortium-filter-discipline">Discipline</label>
          <select id="consortium-filter-discipline" data-filter-discipline>
            <option value="">All disciplines</option>
            <option value="Education">Education</option>
            <option value="Computer Science">Computer Science</option>
            <option value="Law">Law</option>
          </select>
        </div>
      </div>

      <p class="consortium-filters__status" data-filter-status>Showing {{ allPeople.length }} people.</p>
    </div>

    <div class="consortium-grid" data-consortium-grid>
      {% for person in allPeople %}
        {{ renderPersonCard(person, loop.index <= workPackageLeaders.length) }}
      {% endfor %}
    </div>
  </section>
</div>

<script>
  function initConsortiumFilters() {
    var grid = document.querySelector("[data-consortium-grid]");
    var organizationSelect = document.querySelector("[data-filter-organization]");
    var disciplineSelect = document.querySelector("[data-filter-discipline]");
    var status = document.querySelector("[data-filter-status]");

    if (!grid || !organizationSelect || !disciplineSelect || !status) {
      return;
    }

    var cards = Array.prototype.slice.call(grid.querySelectorAll("[data-card]"));

    function normalizeValue(value) {
      return String(value || "").trim().toLowerCase();
    }

    function applyFilters() {
      var organization = normalizeValue(organizationSelect.value);
      var discipline = normalizeValue(disciplineSelect.value);

      var visibleCards = cards.filter(function (card) {
        var organizationMatch = !organization || normalizeValue(card.dataset.organization) === organization;
        var disciplineMatch = !discipline || normalizeValue(card.dataset.discipline) === discipline;
        var visible = organizationMatch && disciplineMatch;
        card.hidden = !visible;
        return visible;
      });

      status.textContent = "Showing " + visibleCards.length + " people.";
    }

    organizationSelect.addEventListener("change", applyFilters);
    disciplineSelect.addEventListener("change", applyFilters);
    applyFilters();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initConsortiumFilters);
  } else {
    initConsortiumFilters();
  }
</script>