<!doctype html>
<html lang="{{ lang if lang else (site.defaultLocale if site and site.defaultLocale else 'fi') }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if seoTitle %}{{ seoTitle }}{% elif title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  {% set _desc = seoDescription if seoDescription else (ogDescription if ogDescription else excerpt) %}
  {% if _desc %}<meta name="description" content="{{ _desc }}">{% endif %}
  {% set _canonical = canonical if canonical else (site.url + page.url) %}
  {% set localeUrlOverrides = {
    "/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/en/home/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/en/welcome-to-the-generation-ai-project-website/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/sv/startsida/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/sv/valkommen-till-generation-ai-projektets-webbplats/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/ajankohtaista/": { "fi": "/ajankohtaista/", "en": "/en/current-affairs/", "sv": "/sv/aktuellt/" },
    "/materiaalit/": { "fi": "/materiaalit/", "en": "/en/materials/", "sv": "/sv/material/" },
    "/hankkeen-toiminta/": { "fi": "/hankkeen-toiminta/", "en": "/en/what-we-do/", "sv": "/sv/verksamhet/" },
    "/en/activities/": { "fi": "/hankkeen-toiminta/", "en": "/en/what-we-do/", "sv": "/sv/verksamhet/" },
    "/en/what-we-do/": { "fi": "/hankkeen-toiminta/", "en": "/en/what-we-do/", "sv": "/sv/verksamhet/" },
    "/sv/atgard/": { "fi": "/hankkeen-toiminta/", "en": "/en/what-we-do/", "sv": "/sv/verksamhet/" },
    "/sv/verksamhet/": { "fi": "/hankkeen-toiminta/", "en": "/en/what-we-do/", "sv": "/sv/verksamhet/" },
    "/konsortio/": { "fi": "/konsortio/", "en": "/en/consortium/", "sv": "/sv/konsortium/" },
    "/ollaan-yhteydessa/": { "fi": "/ollaan-yhteydessa/", "en": "/en/get-in-touch/", "sv": "/sv/kontakta-oss/" },
    "/opettajalle/": { "fi": "/opettajalle/", "en": "/en/for-teachers/", "sv": "/sv/for-larare/" },
    "/generation-ai-hankkeessa-tehtava-tutkimus/": { "fi": "/generation-ai-hankkeessa-tehtava-tutkimus/", "en": "/en/research/", "sv": "/sv/forskning/" },
    "/tietoa-tekoalysta-kenelle-tahansa/": { "fi": "/tietoa-tekoalysta-kenelle-tahansa/", "en": "/en/generation-ai-project-in-the-media/", "sv": "/sv/generation-ai-projektet-i-media/" },
    "/haku/": { "fi": "/haku/", "en": "/en/search/", "sv": "/sv/sok/" },
    "/en/search/": { "fi": "/haku/", "en": "/en/search/", "sv": "/sv/sok/" },
    "/sv/sok/": { "fi": "/haku/", "en": "/en/search/", "sv": "/sv/sok/" }
  } %}
  {% set _localeLinks = translations.byUrl[page.url] if translations and translations.byUrl and page and page.url else {} %}
  {% set _overrideLinks = localeUrlOverrides[page.url] if page and page.url and localeUrlOverrides[page.url] else null %}
  <link rel="canonical" href="{{ _canonical }}">
  {% if _overrideLinks %}
    {% for locale, url in _overrideLinks %}
      {% if url %}
        <link rel="alternate" hreflang="{{ locale }}" href="{{ site.url + url }}">
      {% endif %}
    {% endfor %}
  {% elif _localeLinks %}
    {% for locale, item in _localeLinks %}
      {% if item and item.url %}
        <link rel="alternate" hreflang="{{ locale }}" href="{{ site.url + item.url }}">
      {% endif %}
    {% endfor %}
  {% endif %}
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  <meta property="og:type" content="{% if sourceType == 'posts' %}article{% else %}website{% endif %}">
  <meta property="og:url" content="{{ _canonical }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ ogTitle if ogTitle else (seoTitle if seoTitle else title) }}">
  {% set _ogDesc = ogDescription if ogDescription else _desc %}
  {% if _ogDesc %}<meta property="og:description" content="{{ _ogDesc }}">{% endif %}
  {% if ogImage %}<meta property="og:image" content="{{ ogImage }}">{% endif %}
  <link rel="preload" as="font" type="font/ttf" href="/media/wp-content/uploads/2025/02/Tektur-VariableFont_wdthwght.ttf" crossorigin>
  <link rel="stylesheet" href="/styles/theme.css">
</head>
<body{% if pageHero %} class="has-hero"{% endif %}>
  <div data-pagefind-ignore>{% include "partials/site-header.njk" %}</div>
  <div data-pagefind-body data-pagefind-meta="language:{{ lang if lang else (site.defaultLocale if site and site.defaultLocale else 'fi') }}">
  {{ content | safe }}
  </div>
  <div data-pagefind-ignore>{% include "partials/site-footer.njk" %}</div>
  {% include "partials/cookie-consent-placeholder.njk" %}
  <script src="/scripts/nav.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var PX_PER_SEC = 120;
      document.querySelectorAll('.kb-post-feed-carousel-wrap').forEach(function(wrap) {
        var track = wrap.querySelector('.kb-post-feed-carousel');
        if (!track) return;
        // Duplicate cards for seamless loop
        Array.from(track.children).forEach(function(card) {
          track.appendChild(card.cloneNode(true));
        });
        var halfWidth = track.scrollWidth / 2;
        var paused = false;
        var raf = null;
        var last = null;
        function tick(ts) {
          if (!paused) {
            if (last !== null) {
              track.scrollLeft += PX_PER_SEC * (ts - last) / 1000;
              if (track.scrollLeft >= halfWidth) track.scrollLeft -= halfWidth;
            }
            last = ts;
          } else {
            last = null;
          }
          raf = requestAnimationFrame(tick);
        }
        wrap.addEventListener('mouseenter', function() { paused = true; });
        wrap.addEventListener('mouseleave', function() { paused = false; });
        wrap.addEventListener('touchstart', function() { paused = true; }, { passive: true });
        wrap.addEventListener('touchend', function() { paused = false; }, { passive: true });
        raf = requestAnimationFrame(tick);
      });
    });
  </script>
</body>
</html>
