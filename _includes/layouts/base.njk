<!doctype html>
<html lang="{{ lang if lang else (site.defaultLocale if site and site.defaultLocale else 'fi') }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://assets.mailerlite.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.web3forms.com https://assets.mailerlite.com https://api.github.com; font-src 'self' data:; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self' https://api.web3forms.com;">
  <meta name="referrer" content="strict-origin-when-cross-origin">
  <meta http-equiv="X-Content-Type-Options" content="nosniff">
  <meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=(), payment=(), usb=()">
  <title>{% if seoTitle %}{{ seoTitle }}{% elif title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  {% set _desc = seoDescription if seoDescription else (ogDescription if ogDescription else excerpt) %}
  {% if _desc %}<meta name="description" content="{{ _desc }}">{% endif %}
  {% set _canonical = canonical if canonical else (site.url + page.url) %}
  {% set localeUrlOverrides = {
    "/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/en/home/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/en/welcome-to-the-generation-ai-project-website/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/sv/startsida/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/sv/valkommen-till-generation-ai-projektets-webbplats/": { "fi": "/", "en": "/en/home/", "sv": "/sv/startsida/" },
    "/ajankohtaista/": { "fi": "/ajankohtaista/", "en": "/en/current-affairs/", "sv": "/sv/aktuellt/" },
    "/materiaalit/": { "fi": "/materiaalit/", "en": "/en/materials/", "sv": "/sv/material/" },
    "/hankkeen-toiminta/": { "fi": "/hankkeen-toiminta/", "en": "/en/activities/", "sv": "/sv/verksamhet/" },
    "/en/activities/": { "fi": "/hankkeen-toiminta/", "en": "/en/activities/", "sv": "/sv/verksamhet/" },
    "/en/what-we-do/": { "fi": "/hankkeen-toiminta/", "en": "/en/activities/", "sv": "/sv/verksamhet/" },
    "/sv/atgard/": { "fi": "/hankkeen-toiminta/", "en": "/en/activities/", "sv": "/sv/verksamhet/" },
    "/sv/verksamhet/": { "fi": "/hankkeen-toiminta/", "en": "/en/activities/", "sv": "/sv/verksamhet/" },
    "/konsortio/": { "fi": "/konsortio/", "en": "/en/consortium/", "sv": "/sv/konsortium/" },
    "/ollaan-yhteydessa/": { "fi": "/ollaan-yhteydessa/", "en": "/en/get-in-touch/", "sv": "/sv/kontakta-oss/" },
    "/opettajalle/": { "fi": "/opettajalle/", "en": "/en/for-teachers/", "sv": "/sv/for-larare/" },
    "/tutkijalle/": { "fi": "/tutkijalle/", "en": "/en/research/", "sv": "/sv/forskning/" },
    "/yleisölle/": { "fi": "/yleisölle/", "en": "/en/generation-ai-project-in-the-media/", "sv": "/sv/generation-ai-projektet-i-media/" },
    "/haku/": { "fi": "/haku/", "en": "/en/search/", "sv": "/sv/sok/" },
    "/en/search/": { "fi": "/haku/", "en": "/en/search/", "sv": "/sv/sok/" },
    "/sv/sok/": { "fi": "/haku/", "en": "/en/search/", "sv": "/sv/sok/" }
  } %}
  {% set _localeLinks = translations.byUrl[page.url] if translations and translations.byUrl and page and page.url else {} %}
  {% set _overrideLinks = localeUrlOverrides[page.url] if page and page.url and localeUrlOverrides[page.url] else null %}
  <link rel="canonical" href="{{ _canonical }}">
  <link rel="sitemap" type="application/xml" href="/sitemap.xml">
  {% if _overrideLinks %}
    {% for locale, url in _overrideLinks %}
      {% if url %}
        <link rel="alternate" hreflang="{{ locale }}" href="{{ site.url + url }}">
      {% endif %}
    {% endfor %}
  {% elif _localeLinks %}
    {% for locale, item in _localeLinks %}
      {% if item and item.url %}
        <link rel="alternate" hreflang="{{ locale }}" href="{{ site.url + item.url }}">
      {% endif %}
    {% endfor %}
  {% endif %}
  {# ── Favicon ──────────────────────────────────────────────────────────── #}
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <link rel="apple-touch-icon" href="/media/wp-content/uploads/2023/04/cropped-GenAI-logoluonnos.jpg">
  {# ── Robots / indexing ────────────────────────────────────────────────── #}
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  {# ── Open Graph ───────────────────────────────────────────────────────── #}
  {% set _ogType = "article" if sourceType == "posts" else "website" %}
  {% set _ogTitle = ogTitle if ogTitle else (seoTitle if seoTitle else title) %}
  {% set _ogDesc = ogDescription if ogDescription else _desc %}
  {% set _ogLocale = "fi_FI" %}
  {% if lang == "en" %}{% set _ogLocale = "en_GB" %}{% elif lang == "sv" %}{% set _ogLocale = "sv_SE" %}{% endif %}
  {% set _ogImage = ogImage if ogImage else (site.url + "/media/wp-content/uploads/2023/04/cropped-GenAI-logoluonnos.jpg") %}
  <meta property="og:type" content="{{ _ogType }}">
  <meta property="og:url" content="{{ _canonical }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="{{ _ogLocale }}">
  <meta property="og:title" content="{{ _ogTitle }}">
  {% if _ogDesc %}<meta property="og:description" content="{{ _ogDesc }}">{% endif %}
  <meta property="og:image" content="{{ _ogImage }}">
  {% if _ogType == "article" %}
  <meta property="article:published_time" content="{{ date | rssDate if date else "" }}">
  {% if updated %}<meta property="article:modified_time" content="{{ updated | rssDate }}">{% endif %}
  {% endif %}
  {# ── Twitter / X Card ────────────────────────────────────────────────── #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ _ogTitle }}">
  {% if _ogDesc %}<meta name="twitter:description" content="{{ _ogDesc }}">{% endif %}
  <meta name="twitter:image" content="{{ _ogImage }}">
  {# ── RSS feeds ────────────────────────────────────────────────────────── #}
  {% set _feedLocale = lang if lang else (site.defaultLocale if site and site.defaultLocale else "fi") %}
  {% if _feedLocale == "en" %}
    <link rel="alternate" type="application/rss+xml" title="{{ site.name }} (EN)" href="{{ site.url }}/en/feed.xml">
  {% elif _feedLocale == "sv" %}
    <link rel="alternate" type="application/rss+xml" title="{{ site.name }} (SV)" href="{{ site.url }}/sv/feed.xml">
  {% else %}
    <link rel="alternate" type="application/rss+xml" title="{{ site.name }}" href="{{ site.url }}/feed.xml">
  {% endif %}
  <link rel="stylesheet" href="/styles/theme.css">
  <link rel="stylesheet" href="/styles/cookieconsent.css">
</head>
<body{% if pageHero %} class="has-hero"{% endif %}>
  {% set _skipLabel = "Siirry pääsisältöön" %}
  {% if lang == "en" %}{% set _skipLabel = "Skip to main content" %}{% elif lang == "sv" %}{% set _skipLabel = "Hoppa till huvudinnehåll" %}{% endif %}
  <a class="skip-to-main" href="#main-content">{{ _skipLabel }}</a>
  {% include "partials/site-header.njk" %}
  <div data-pagefind-body data-pagefind-meta="language:{{ lang if lang else (site.defaultLocale if site and site.defaultLocale else 'fi') }}">
  {{ content | safe }}
  </div>
  <div data-pagefind-ignore>{% include "partials/site-footer.njk" %}</div>
  {% include "partials/cookie-consent-placeholder.njk" %}
  {% if mailerlite and mailerlite.accountId %}
  <script data-mailerlite-account="{{ mailerlite.accountId }}" data-cookiecategory="marketing" type="text/plain">
    (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[]).push(arguments);},l=d.createElement(e),l.async=1,l.src=u,n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})(window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
    ml('account','{{ mailerlite.accountId }}');
  </script>
  {% endif %}
  <script src="/scripts/nav.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var PX_PER_SEC = 120;
      document.querySelectorAll('.kb-post-feed-carousel-wrap').forEach(function(wrap) {
        var track = wrap.querySelector('.kb-post-feed-carousel');
        if (!track) return;
        // Duplicate cards for seamless loop
        Array.from(track.children).forEach(function(card) {
          track.appendChild(card.cloneNode(true));
        });
        var halfWidth = track.scrollWidth / 2;
        var paused = false;
        var raf = null;
        var last = null;
        function tick(ts) {
          if (!paused) {
            if (last !== null) {
              track.scrollLeft += PX_PER_SEC * (ts - last) / 1000;
              if (track.scrollLeft >= halfWidth) track.scrollLeft -= halfWidth;
            }
            last = ts;
          } else {
            last = null;
          }
          raf = requestAnimationFrame(tick);
        }
        wrap.addEventListener('mouseenter', function() { paused = true; });
        wrap.addEventListener('mouseleave', function() { paused = false; });
        wrap.addEventListener('touchstart', function() { paused = true; }, { passive: true });
        wrap.addEventListener('touchend', function() { paused = false; }, { passive: true });
        raf = requestAnimationFrame(tick);
      });
    });
  </script>
</body>
</html>
