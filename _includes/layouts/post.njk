---
layout: layouts/base.njk
---
{% set _lang = lang if lang else "fi" %}
{% set _searchBase = "/en/search/" if _lang == "en" else ("/sv/sok/" if _lang == "sv" else "/haku/") %}
{% set _postCollection = collections.posts_en if _lang == "en" else (collections.posts_sv if _lang == "sv" else collections.posts_fi) %}
{% set _relPosts = _postCollection | relatedPosts(page.url, tags) %}
{% set _relatedCategoryAllowlist = [
  "Ajankohtaista",
  "Current affairs",
  "Nyheter",
  "Nyheter från",
  "GenAI hankkeen henkilöstö mediassa",
  "GenAI hankkeen henkilöstö tapahtumissa",
  "Hankkeen toiminta",
  "Tutkimus",
  "GenAI project staff in the media",
  "GenAI Project Staff in Media",
  "GenAI project staff in media",
  "GenAI Project Staff in the Media",
  "GenAI project staff at events",
  "GenAI Project Staff at Events",
  "GenAI project staff events",
  "Project activities",
  "Project Activities",
  "Research",
  "GenAI-projektets personal i media",
  "GenAI-projektets medarbetare i media",
  "GenAI-projektets personal vid evenemang",
  "GenAI-projektets personal på evenemang",
  "GenAI-projektpersonalens evenemang",
  "Projektaktiviteter",
  "Projektverksamhet",
  "Forskning"
] %}
{% set _showRelatedContent = false %}
{% for _category in categories or [] %}
  {% if _category in _relatedCategoryAllowlist %}
    {% set _showRelatedContent = true %}
  {% endif %}
{% endfor %}

{% set _catUrls = {
  "Ajankohtaista": "/ajankohtaista/",
  "Hankkeen toiminta": "/hankkeen-toiminta/",
  "Tutkimus": "/tutkijalle/",
  "GenAI hankkeen henkilöstö mediassa": "/medialle/",
  "GenAI hankkeen henkilöstö tapahtumissa": "/ajankohtaista/#tab-tapahtumat",
  "Konferenssit ja seminaarit": "/ajankohtaista/#tab-tapahtumat",
  "Webinaari": "/ajankohtaista/#tab-tapahtumat",
  "Työpaja": "/ajankohtaista/#tab-tapahtumat",
  "Haastattelu": "/medialle/",
  "News": "/en/current-affairs/",
  "News from": "/en/current-affairs/",
  "Project activities": "/en/activities/",
  "Research": "/en/research/",
  "GenAI project staff at events": "/en/activities/",
  "GenAI project staff in the media": "/en/for-everyone/",
  "GenAI Project Staff in Media": "/en/for-everyone/",
  "GenAI Project Staff at Events": "/en/activities/",
  "Webinar": "/en/activities/",
  "Interview": "/en/for-everyone/",
  "Nyheter": "/sv/aktuellt/",
  "Projektets verksamhet": "/sv/verksamhet/",
  "Forskning": "/sv/forskning/"
} %}

<main class="post">
  <div class="post-inner">
    <header class="post-header">
      {% if categories and categories.length %}
      <div class="post-categories">
        {% for c in categories %}
        {% set _href = _catUrls[c] if _catUrls[c] else (_searchBase + "?q=" + (c | urlencode)) %}
        <a class="post-category" href="{{ _href }}">{{ c }}</a>
        {% endfor %}
      </div>
      {% endif %}
      <h1 class="post-title">{{ title }}</h1>
      {% if date %}<time class="post-date" datetime="{{ date }}">{{ date | date("d.m.Y") }}</time>{% endif %}
      {% if featuredImage %}<img class="post-featured-image" src="{{ featuredImage }}" alt="{{ title }}">{% endif %}
    </header>

    <div class="post-content">{{ content | safe }}</div>

    {% if tags and tags.length %}
    <footer class="post-footer">
      <div class="post-tags">
        {% for tag in tags %}
        <a class="post-tag" href="{{ _searchBase }}?q={{ tag | urlencode }}">{{ tag }}</a>
        {% endfor %}
      </div>
    </footer>
    {% endif %}

    {% if _showRelatedContent %}
      {% include "partials/related-content.njk" %}
    {% endif %}
  </div>
</main>
