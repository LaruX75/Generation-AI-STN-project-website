---
layout: layouts/base.njk
---
<main class="page search-page" data-pagefind-ignore>
  <h1 class="page-title">{{ title }}</h1>
  <div id="search-ui"></div>
</main>
<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
<script src="/pagefind/pagefind-ui.js"></script>
<script>
  window.addEventListener('DOMContentLoaded', function () {
    new PagefindUI({
      element: '#search-ui',
      showImages: true,
      showEmptyFilters: false,
      excerptLength: 20,
      translations: {
        placeholder: '{{ searchUi.placeholder }}',
        zero_results: '{{ searchUi.zeroResults }}'
      }
    });

    // Pre-fill query from URL ?q=...
    var params = new URLSearchParams(location.search);
    var q = params.get('q');
    if (q) {
      var input = document.querySelector('.pagefind-ui__search-input');
      if (input) { input.value = q; input.dispatchEvent(new Event('input')); }
    }
  });
</script>
