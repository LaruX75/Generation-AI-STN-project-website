{# kadence/postgrid — Eleventy collection grid fallback for dynamic posts block #}
{% set b = kadenceBlock.attrs %}
{% set count = b.postsToShow if b.postsToShow else (b.numberOfItems if b.numberOfItems else 6) %}
{% set collectionName = b.collection if b.collection else "posts" %}
{% set sourceItems = collections[collectionName] if collections and collections[collectionName] else collections.posts %}
{% set items = sourceItems | localizedItems(lang, page.url) | limitItems(count) %}
{% set isCarousel = b.postLayout == "carousel" %}
<section class="kb-post-grid{% if isCarousel %} kb-post-grid--carousel alignfull{% endif %}{% if b.className %} {{ b.className }}{% endif %}">
  {% if kadenceInnerHtml | trim %}
    {{ kadenceInnerHtml | safe }}
  {% elif isCarousel %}
    {% if b.title %}
      <header class="kb-post-feed-header">
        <h2 class="kb-post-feed-title">{{ b.title }}</h2>
      </header>
    {% endif %}
    <div class="kb-post-feed-carousel-wrap">
      <button class="kb-carousel-btn kb-carousel-btn--prev kb-carousel-btn--edge" aria-label="Edellinen">&#8249;</button>
      <div class="kb-post-feed-carousel" id="kbc-{{ b.uniqueID }}">
        {% for post in items %}
          <article class="kb-post-card">
            {% if post.data.featuredImage %}
              <a class="kb-post-card__image-link" href="{{ post.url }}">
                <img class="kb-post-card__image" src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}">
              </a>
            {% endif %}
            <div class="kb-post-card__body">
              {% if post.date %}
                <time class="kb-post-card__date" datetime="{{ post.date | date('Y-m-d') }}">{{ post.date | date('d.m.Y') }}</time>
              {% endif %}
              <h3 class="kb-post-card__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
              {% if post.data.excerpt %}
                <p class="kb-post-card__excerpt">{{ post.data.excerpt }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
      <button class="kb-carousel-btn kb-carousel-btn--next" aria-label="Seuraava">&#8250;</button>
      <script>
      (function () {
        var track = document.getElementById('kbc-{{ b.uniqueID }}');
        if (!track) return;
        var wrap  = track.parentElement;
        var btnPrev = wrap.querySelector('.kb-carousel-btn--prev');
        var btnNext = wrap.querySelector('.kb-carousel-btn--next');
        if (!btnPrev || !btnNext) return;

        function cardStep() {
          var card = track.querySelector('.kb-post-card');
          if (!card) return 300;
          var gap = parseFloat(getComputedStyle(track).columnGap) || 20;
          return card.offsetWidth + gap;
        }

        function sync() {
          var atStart = track.scrollLeft <= 4;
          var atEnd   = track.scrollLeft + track.clientWidth >= track.scrollWidth - 4;
          btnPrev.classList.toggle('kb-carousel-btn--edge', atStart);
          btnNext.classList.toggle('kb-carousel-btn--edge', atEnd);
        }

        requestAnimationFrame(sync);
        btnPrev.addEventListener('click', function () {
          track.scrollBy({ left: -cardStep(), behavior: 'smooth' });
        });
        btnNext.addEventListener('click', function () {
          track.scrollBy({ left: cardStep(), behavior: 'smooth' });
        });
        track.addEventListener('scroll', sync, { passive: true });
        window.addEventListener('resize', function () { requestAnimationFrame(sync); }, { passive: true });
      })();
      </script>
    </div>
  {% else %}
    {% if b.title %}
      <header class="kb-post-feed-header">
        <h2 class="kb-post-feed-title">{{ b.title }}</h2>
      </header>
    {% endif %}
    <div class="kb-post-feed-grid">
      {% for post in items %}
        <article class="kb-post-card">
          {% if post.data.featuredImage %}
            <a class="kb-post-card__image-link" href="{{ post.url }}">
              <img class="kb-post-card__image" src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}">
            </a>
          {% endif %}
          <div class="kb-post-card__body">
            {% if post.date %}
              <time class="kb-post-card__date" datetime="{{ post.date | date('Y-m-d') }}">{{ post.date | date('d.m.Y') }}</time>
            {% endif %}
            <h3 class="kb-post-card__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
            {% if post.data.excerpt %}
              <p class="kb-post-card__excerpt">{{ post.data.excerpt }}</p>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}
</section>
