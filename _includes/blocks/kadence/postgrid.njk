{# kadence/postgrid — Splide carousel or grid of posts #}
{% set b = kadenceBlock.attrs %}
{% set count = b.postsToShow if b.postsToShow else 6 %}
{% set isCarousel = b.postLayout == "carousel" %}
{% set uid = b.uniqueID | replace("_", "") %}
{% set colName = b.collection if b.collection else "posts" %}
{% set postItems = collections[colName] if collections[colName] else collections.posts %}
{% set postItems = postItems | reverse if postItems else [] %}

<section class="wp-block-kadence-postgrid kb-post-grid kadence-block kadence-postgrid{% if isCarousel %} kt-post-grid-layout-carousel{% endif %}{% if b.uniqueID %} kt-post-loop{{ uid }}{% endif %}{% if b.className %} {{ b.className }}{% endif %}">
  {% if kadenceInnerHtml | trim %}
    {{ kadenceInnerHtml | safe }}
  {% elif isCarousel %}
    <div class="kt-post-grid-carousel-wrap splide kadence-splide-init" id="splide-{{ uid }}"
      data-splide='{"type":"loop","perPage":3,"perMove":1,"gap":"1.25rem","arrows":true,"pagination":true,"breakpoints":{"768":{"perPage":1},"1024":{"perPage":2}}}'>
      <div class="splide__track">
        <div class="kadence-splide-slider-wrap splide__list">
          {% for post in postItems %}
            {% if loop.index <= count %}
              <div class="kt-post-slider-item splide__slide">
                <article class="kt-blocks-post-grid-item">
                  {% if post.data.featuredImage %}
                    <div class="kt-blocks-post-grid-item-img">
                      <a href="{{ post.url }}">
                        <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}" loading="lazy">
                      </a>
                    </div>
                  {% endif %}
                  <div class="kt-blocks-post-grid-item-body">
                    <header>
                      <h2 class="kt-blocks-post-title">
                        <a href="{{ post.url }}">{{ post.data.title }}</a>
                      </h2>
                    </header>
                    {% if post.data.excerpt %}
                      <p class="kt-blocks-post-excerpt">{{ post.data.excerpt | truncate(120) }}</p>
                    {% endif %}
                  </div>
                </article>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% else %}
    <div class="kb-post-grid-layout-masonry" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem;">
      {% for post in postItems %}
        {% if loop.index <= count %}
          <article class="kt-blocks-post-grid-item">
            {% if post.data.featuredImage %}
              <div class="kt-blocks-post-grid-item-img">
                <a href="{{ post.url }}"><img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}" loading="lazy"></a>
              </div>
            {% endif %}
            <div class="kt-blocks-post-grid-item-body">
              <h2 class="kt-blocks-post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
              {% if post.data.excerpt %}<p class="kt-blocks-post-excerpt">{{ post.data.excerpt | truncate(120) }}</p>{% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</section>
