{# kadence/tabs — Tab group with title nav and switchable panels #}
{% set b = kadenceBlock.attrs %}
<div class="kb-tabs{% if b.uniqueID %} kb-tabs-id_{{ b.uniqueID }}{% endif %}{% if b.className %} {{ b.className }}{% endif %}">
  {{ kadenceInnerHtml | safe }}
</div>
<script>
(function () {
  if (window._ktTabsInit) return;
  window._ktTabsInit = true;
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.kb-tabs').forEach(function (wrap) {
      var panels = Array.from(wrap.querySelectorAll('.kt-tabs-content-wrap > .kb-tab-panel'));
      var titleItems = Array.from(wrap.querySelectorAll('.kt-tabs-title-list .kt-title-item'));
      var titleLinks = Array.from(wrap.querySelectorAll('.kt-tabs-title-list .kt-tab-title'));
      function activate(idx) {
        panels.forEach(function (p, i) { p.classList.toggle('kt-tab-active', i === idx); });
        titleItems.forEach(function (li, i) {
          li.classList.toggle('kt-tab-title-active', i === idx);
          li.classList.toggle('kt-tab-title-inactive', i !== idx);
        });
      }
      function idxFromHash(hash) {
        if (!hash) return -1;
        var id = hash.replace(/^#/, '');
        return titleItems.findIndex(function (li) { return li.id === id; });
      }
      wrap.classList.add('kb-tabs-js-ready');
      var hashIdx = idxFromHash(window.location.hash);
      var initIdx = hashIdx >= 0 ? hashIdx : titleItems.findIndex(function (li) { return li.classList.contains('kt-tab-title-active'); });
      activate(initIdx >= 0 ? initIdx : 0);
      titleLinks.forEach(function (link) {
        link.addEventListener('click', function (e) {
          e.preventDefault();
          var tabNum = parseInt(link.getAttribute('data-tab'), 10);
          if (!isNaN(tabNum)) {
            activate(tabNum - 1);
            var li = titleItems[tabNum - 1];
            if (li && li.id) history.replaceState(null, '', '#' + li.id);
          }
        });
      });
      window.addEventListener('hashchange', function () {
        var idx = idxFromHash(window.location.hash);
        if (idx >= 0) activate(idx);
      });
    });
  });
}());
</script>
