{# kadence/lottie (PRO) — Lottie animation; requires @lottiefiles/lottie-player script #}
{% set b = kadenceBlock.attrs %}
<div
  class="wp-block-kadence-lottie kb-lottie-wrap kadence-block kadence-lottie{% if b.className %} {{ b.className }}{% endif %}"
>
  {% if b.fileUrl %}
    <lottie-player
      src="{{ b.fileUrl }}"
      {% if b.loop %}loop{% endif %}
      {% if b.autoplay %}autoplay{% endif %}
      style="width:100%"
    ></lottie-player>
  {% else %}
    {{ kadenceInnerHtml | safe }}
  {% endif %}
</div>
