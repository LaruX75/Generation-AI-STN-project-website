{% set allCards = toimintaCards or [] %}

{% if lang == "en" %}
  {% set lbl = {
    "heading": "Project activities", "search": "Search activities", "placeholder": "Search by title…",
    "typeLabel": "Filter by type", "typeAll": "All types",
    "typePost": "Publications", "typeStake": "Stakeholder collaboration",
    "badgePost": "Publication", "badgeStake": "Stakeholder",
    "yrLabel": "Filter by year", "yrAll": "All years",
    "aria": "Project activities", "ariaPag": "Result page",
    "colDate": "Date", "colType": "Type", "colTitle": "Title / Topic", "colExtra": "Stakeholder / Details", "colLink": "Link",
    "open": "Open", "na": "—", "empty": "No results.",
    "prev": "← Previous", "next": "Next →",
    "jsPage": "Page", "jsSep": "/", "jsResults": "results"
  } %}
{% elif lang == "sv" %}
  {% set lbl = {
    "heading": "Projektverksamhet", "search": "Sök verksamhet", "placeholder": "Sök på rubrik…",
    "typeLabel": "Filtrera efter typ", "typeAll": "Alla typer",
    "typePost": "Publikationer", "typeStake": "Intressentsamarbete",
    "badgePost": "Publikation", "badgeStake": "Intressent",
    "yrLabel": "Filtrera efter år", "yrAll": "Alla år",
    "aria": "Projektverksamhet", "ariaPag": "Resultatsida",
    "colDate": "Datum", "colType": "Typ", "colTitle": "Rubrik / Ämne", "colExtra": "Intressent / Detaljer", "colLink": "Länk",
    "open": "Öppna", "na": "—", "empty": "Inga resultat.",
    "prev": "← Föregående", "next": "Nästa →",
    "jsPage": "Sida", "jsSep": "/", "jsResults": "resultat"
  } %}
{% else %}
  {% set lbl = {
    "heading": "Hankkeen toiminta", "search": "Hae toiminnasta", "placeholder": "Hae otsikolla…",
    "typeLabel": "Suodata tyypeittäin", "typeAll": "Kaikki tyypit",
    "typePost": "Julkaisut ja raportit", "typeStake": "Sidosryhmäyhteistyö",
    "badgePost": "Julkaisu", "badgeStake": "Sidosryhmä",
    "yrLabel": "Suodata vuoden mukaan", "yrAll": "Kaikki vuodet",
    "aria": "Hankkeen toiminta", "ariaPag": "Tulossivu",
    "colDate": "Päivämäärä", "colType": "Tyyppi", "colTitle": "Otsikko / Aihe", "colExtra": "Sidosryhmä / Lisätiedot", "colLink": "Linkki",
    "open": "Avaa", "na": "—", "empty": "Ei tuloksia.",
    "prev": "← Edellinen", "next": "Seuraava →",
    "jsPage": "Sivu", "jsSep": "/", "jsResults": "tulosta"
  } %}
{% endif %}

<section class="media-table-section" id="toiminta-table-section" data-grid-enhance>

  <div class="media-table-header">
    <h2 class="media-table-heading">{{ lbl.heading }}</h2>
    <div class="media-table-controls">
      <div class="media-table-search-wrap">
        <label for="toiminta-search" class="sr-only">{{ lbl.search }}</label>
        <input type="search" id="toiminta-search" class="media-table-search" placeholder="{{ lbl.placeholder }}" autocomplete="off" data-grid-search>
      </div>
      <div class="media-table-filters">
        <label for="toiminta-filter-type" class="sr-only">{{ lbl.typeLabel }}</label>
        <select id="toiminta-filter-type" class="media-table-filter" data-grid-filter="type">
          <option value="">{{ lbl.typeAll }}</option>
          <option value="post">{{ lbl.typePost }}</option>
          <option value="stakeholder">{{ lbl.typeStake }}</option>
        </select>
        <label for="toiminta-filter-year" class="sr-only">{{ lbl.yrLabel }}</label>
        <select id="toiminta-filter-year" class="media-table-filter" data-grid-filter="year" data-grid-populate-options="year">
          <option value="">{{ lbl.yrAll }}</option>
        </select>
      </div>
      <p class="media-table-count" id="toiminta-count" aria-live="polite" data-grid-count></p>
    </div>
  </div>

  <div class="media-table-wrap" role="region" aria-label="{{ lbl.aria }}">
    <table class="media-table" id="toiminta-table" data-grid-source>
      <thead>
        <tr>
          <th scope="col" class="media-table-col--date">{{ lbl.colDate }}</th>
          <th scope="col" class="media-table-col--source">{{ lbl.colType }}</th>
          <th scope="col" class="media-table-col--title">{{ lbl.colTitle }}</th>
          <th scope="col" class="toiminta-table-col--extra media-table-col--mobile-hide">{{ lbl.colExtra }}</th>
          <th scope="col" class="media-table-col--link media-table-col--mobile-hide">{{ lbl.colLink }}</th>
        </tr>
      </thead>
      <tbody id="toiminta-table-body">
        {% for card in allCards %}
          {% if card.cardType == "post" %}
            {% set post = card.post %}
            <tr class="media-table-row"
              data-type="post"
              data-year="{{ post.date | date('Y') }}"
              data-search="{{ post.data.title | lower | default('') }}">
              <td class="media-table-col--date">
                <time datetime="{{ post.date | date('Y-m-d') }}">{{ post.date | date("d.m.Y") }}</time>
              </td>
              <td class="media-table-col--source">
                <span class="media-table-source-badge toiminta-badge--post">{{ lbl.badgePost }}</span>
              </td>
              <td class="media-table-col--title">
                <a href="{{ post.url }}" class="media-table-title-link">{{ post.data.title | default("—") }}</a>
              </td>
              <td class="toiminta-table-col--extra media-table-col--mobile-hide">
                {% if post.data.excerpt and post.data.excerpt != "[object Object]" %}
                  {{ post.data.excerpt | truncate(200) }}
                {% else %}
                  <span class="media-table-na">{{ lbl.na }}</span>
                {% endif %}
              </td>
              <td class="media-table-col--link media-table-col--mobile-hide">
                <a href="{{ post.url }}" class="media-table-link">{{ lbl.open }}&nbsp;↗</a>
              </td>
            </tr>
          {% else %}
            {% set row = card.row %}
            <tr class="media-table-row"
              data-type="stakeholder"
              data-year="{{ row.sortDate | truncate(4, true, '') if row.sortDate else '' }}"
              data-search="{{ (row.title or row.stakeholder) | lower | default('') }}">
              <td class="media-table-col--date">
                <time datetime="{{ row.sortDate | default('') }}">{{ row.displayDate or row.date | default("—") }}</time>
              </td>
              <td class="media-table-col--source">
                <span class="media-table-source-badge toiminta-badge--stakeholder">{{ lbl.badgeStake }}</span>
              </td>
              <td class="media-table-col--title">{{ (row.title or row.stakeholder) | default("—") }}</td>
              <td class="toiminta-table-col--extra media-table-col--mobile-hide">
                <span class="toiminta-stakeholder-name">{{ row.stakeholder | default("") }}</span>
                {% if row.participants %}
                  <span class="toiminta-participants">{{ row.participants }}&nbsp;{{ lbl.participantsSuffix if lbl.participantsSuffix else "osallistujaa" }}</span>
                {% endif %}
              </td>
              <td class="media-table-col--link media-table-col--mobile-hide">
                <span class="media-table-na">—</span>
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
    <p class="media-table-empty" id="toiminta-empty" hidden>{{ lbl.empty }}</p>
  </div>

  <nav class="media-table-pagination" id="toiminta-pagination" aria-label="{{ lbl.ariaPag }}">
    <button class="media-table-page-btn" id="toiminta-prev" aria-label="{{ lbl.prev }}">{{ lbl.prev }}</button>
    <span class="media-table-page-info" id="toiminta-page-info" aria-live="polite"></span>
    <button class="media-table-page-btn" id="toiminta-next" aria-label="{{ lbl.next }}">{{ lbl.next }}</button>
  </nav>

</section>
