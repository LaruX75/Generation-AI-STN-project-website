{% set allCards = toimintaCards or [] %}

<section class="media-table-section" id="toiminta-table-section">

  <div class="media-table-header">
    <h2 class="media-table-heading">Hankkeen toiminta</h2>
    <div class="media-table-controls">
      <div class="media-table-search-wrap">
        <label for="toiminta-search" class="sr-only">Hae toiminnasta</label>
        <input type="search" id="toiminta-search" class="media-table-search" placeholder="Hae otsikolla…" autocomplete="off">
      </div>
      <div class="media-table-filters">
        <label for="toiminta-filter-type" class="sr-only">Suodata tyypeittäin</label>
        <select id="toiminta-filter-type" class="media-table-filter">
          <option value="">Kaikki tyypit</option>
          <option value="post">Julkaisut ja raportit</option>
          <option value="stakeholder">Sidosryhmäyhteistyö</option>
        </select>
        <label for="toiminta-filter-year" class="sr-only">Suodata vuoden mukaan</label>
        <select id="toiminta-filter-year" class="media-table-filter">
          <option value="">Kaikki vuodet</option>
        </select>
      </div>
      <p class="media-table-count" id="toiminta-count" aria-live="polite"></p>
    </div>
  </div>

  <div class="media-table-wrap" role="region" aria-label="Hankkeen toiminta" tabindex="0">
    <table class="media-table" id="toiminta-table">
      <thead>
        <tr>
          <th scope="col" class="media-table-col--date">Päivämäärä</th>
          <th scope="col" class="media-table-col--source">Tyyppi</th>
          <th scope="col" class="media-table-col--title">Otsikko / Aihe</th>
          <th scope="col" class="toiminta-table-col--extra">Sidosryhmä / Lisätiedot</th>
          <th scope="col" class="media-table-col--link">Linkki</th>
        </tr>
      </thead>
      <tbody id="toiminta-table-body">
        {% for card in allCards %}
          {% if card.cardType == "post" %}
            {% set post = card.post %}
            <tr class="media-table-row"
              data-type="post"
              data-year="{{ post.date | date('Y') }}"
              data-search="{{ post.data.title | lower | default('') }}">
              <td class="media-table-col--date">
                <time datetime="{{ post.date | date('Y-m-d') }}">{{ post.date | date("d.m.Y") }}</time>
              </td>
              <td class="media-table-col--source">
                <span class="media-table-source-badge toiminta-badge--post">Julkaisu</span>
              </td>
              <td class="media-table-col--title">{{ post.data.title | default("—") }}</td>
              <td class="toiminta-table-col--extra">
                {% if post.data.excerpt and post.data.excerpt != "[object Object]" %}
                  {{ post.data.excerpt | truncate(200) }}
                {% else %}
                  <span class="media-table-na">—</span>
                {% endif %}
              </td>
              <td class="media-table-col--link">
                <a href="{{ post.url }}" class="media-table-link">Avaa&nbsp;↗</a>
              </td>
            </tr>
          {% else %}
            {% set row = card.row %}
            <tr class="media-table-row"
              data-type="stakeholder"
              data-year="{{ row.sortDate | truncate(4, true, '') if row.sortDate else '' }}"
              data-search="{{ (row.title or row.stakeholder) | lower | default('') }}">
              <td class="media-table-col--date">
                <time datetime="{{ row.sortDate | default('') }}">{{ row.displayDate or row.date | default("—") }}</time>
              </td>
              <td class="media-table-col--source">
                <span class="media-table-source-badge toiminta-badge--stakeholder">Sidosryhmä</span>
              </td>
              <td class="media-table-col--title">{{ (row.title or row.stakeholder) | default("—") }}</td>
              <td class="toiminta-table-col--extra">
                <span class="toiminta-stakeholder-name">{{ row.stakeholder | default("") }}</span>
                {% if row.participants %}
                  <span class="toiminta-participants">{{ row.participants }}&nbsp;osallistujaa</span>
                {% endif %}
              </td>
              <td class="media-table-col--link">
                <span class="media-table-na">—</span>
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
    <p class="media-table-empty" id="toiminta-empty" hidden>Ei tuloksia.</p>
  </div>

  <nav class="media-table-pagination" id="toiminta-pagination" aria-label="Tulossivu">
    <button class="media-table-page-btn" id="toiminta-prev" aria-label="Edellinen sivu">← Edellinen</button>
    <span class="media-table-page-info" id="toiminta-page-info" aria-live="polite"></span>
    <button class="media-table-page-btn" id="toiminta-next" aria-label="Seuraava sivu">Seuraava →</button>
  </nav>

</section>

<script>
(function () {
  var PAGE_SIZE = 10;
  var tbody    = document.getElementById('toiminta-table-body');
  var emptyEl  = document.getElementById('toiminta-empty');
  var searchEl = document.getElementById('toiminta-search');
  var typeEl   = document.getElementById('toiminta-filter-type');
  var yrEl     = document.getElementById('toiminta-filter-year');
  var prevBtn  = document.getElementById('toiminta-prev');
  var nextBtn  = document.getElementById('toiminta-next');
  var pageInfo = document.getElementById('toiminta-page-info');
  var countEl  = document.getElementById('toiminta-count');
  if (!tbody) return;

  var allRows = Array.from(tbody.querySelectorAll('.media-table-row'));
  var filtered = allRows.slice();
  var currentPage = 1;

  // Populate year filter
  (function () {
    var years = {};
    allRows.forEach(function (row) { var y = row.dataset.year; if (y) years[y] = true; });
    Object.keys(years).sort().reverse().forEach(function (yr) {
      var opt = document.createElement('option');
      opt.value = yr; opt.textContent = yr;
      yrEl.appendChild(opt);
    });
  }());

  function applyFilters() {
    var q   = searchEl.value.toLowerCase().trim();
    var typ = typeEl.value;
    var yr  = yrEl.value;
    filtered = allRows.filter(function (row) {
      if (yr  && row.dataset.year !== yr) return false;
      if (typ && row.dataset.type !== typ) return false;
      if (q   && row.dataset.search.indexOf(q) === -1) return false;
      return true;
    });
  }

  function render() {
    applyFilters();
    var total = filtered.length;
    var totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;
    var start = (currentPage - 1) * PAGE_SIZE;
    allRows.forEach(function (row) { row.hidden = true; });
    filtered.slice(start, start + PAGE_SIZE).forEach(function (row) { row.hidden = false; });
    emptyEl.hidden = total > 0;
    prevBtn.disabled = currentPage <= 1;
    nextBtn.disabled = currentPage >= totalPages;
    pageInfo.textContent = 'Sivu\u00a0' + currentPage + '\u00a0/\u00a0' + totalPages;
    countEl.textContent  = total + '\u00a0tulosta';
  }

  searchEl.addEventListener('input',  function () { currentPage = 1; render(); });
  typeEl.addEventListener('change',   function () { currentPage = 1; render(); });
  yrEl.addEventListener('change',     function () { currentPage = 1; render(); });
  prevBtn.addEventListener('click',   function () { if (currentPage > 1) { currentPage--; render(); } });
  nextBtn.addEventListener('click',   function () {
    if (currentPage < Math.max(1, Math.ceil(filtered.length / PAGE_SIZE))) { currentPage++; render(); }
  });

  render();
}());
</script>
