{# Language switcher — links to root for default locale, /xx/ for others #}
{% if site and site.locales and site.locales.length > 1 %}
<nav class="language-switcher" aria-label="Language switcher">
  <ul>
    {% for locale in site.locales %}
      {% set _href = "/" if locale == site.defaultLocale else ("/" + locale + "/") %}
      {% set _active = (lang == locale) or (not lang and locale == site.defaultLocale) %}
      <li><a href="{{ _href }}"{% if _active %} aria-current="true" class="is-active"{% endif %}>{{ locale | upper }}</a></li>
    {% endfor %}
  </ul>
</nav>
{% endif %}
