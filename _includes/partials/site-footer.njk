{% set logos = logosUi[localeCode] if logosUi[localeCode] else logosUi["fi"] %}

<div class="footer-logos">
  <div class="footer-logos-inner">
    <div class="footer-logos-group">
      <span class="footer-logos-label">{{ logos.funderLabel }}</span>
      <div class="footer-logos-list">
        {% for org in logos.funder %}
        {% if localeCode == "en" %}{% set _newTab = " (opens in new tab)" %}{% elif localeCode == "sv" %}{% set _newTab = " (öppnas i ny flik)" %}{% else %}{% set _newTab = " (avautuu uudessa välilehdessä)" %}{% endif %}
        <a class="footer-logo-item" href="{{ org.url }}" target="_blank" rel="noopener" aria-label="{{ org.name }}{{ _newTab }}">
          {% if org.logoUrl %}
          <img class="footer-logo-img {{ org.logoClass }}" src="{{ org.logoUrl }}" alt="{{ org.name }}">
          {% else %}
          <span class="footer-logo-text">{{ org.name }}</span>
          {% endif %}
        </a>
        {% endfor %}
      </div>
    </div>
    <div class="footer-logos-group">
      <span class="footer-logos-label">{{ logos.partnerLabel }}</span>
      <div class="footer-logos-list">
        {% for org in logos.partners %}
        {% if localeCode == "en" %}{% set _newTab = " (opens in new tab)" %}{% elif localeCode == "sv" %}{% set _newTab = " (öppnas i ny flik)" %}{% else %}{% set _newTab = " (avautuu uudessa välilehdessä)" %}{% endif %}
        <a class="footer-logo-item" href="{{ org.url }}" target="_blank" rel="noopener" aria-label="{{ org.name }}{{ _newTab }}">
          {% if org.logoUrl %}
          <img class="footer-logo-img {{ org.logoClass }}" src="{{ org.logoUrl }}" alt="{{ org.name }}">
          {% else %}
          <span class="footer-logo-text">{{ org.name }}</span>
          {% endif %}
        </a>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<div class="genai-brand-strip">
  <div class="genai-brand-strip-inner">
    <div class="genai-brand-strip-text">
      <span class="genai-brand-strip-eyebrow">{{ brand.eyebrow }}</span>
      <span class="genai-brand-strip-wordmark">gen&#8209;ai.fi</span>
      <p class="genai-brand-strip-lead">{{ brand.lead }}</p>
    </div>
    <a class="genai-brand-strip-cta" href="{{ brand.url }}" target="_blank" rel="noopener">
      {{ brand.cta }} <span aria-hidden="true">↗</span><span class="sr-only">{% if localeCode == "en" %}(opens in new tab){% elif localeCode == "sv" %}(öppnas i ny flik){% else %}(avautuu uudessa välilehdessä){% endif %}</span>
    </a>
  </div>
</div>

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-cols">

      <div class="site-footer-col">
        <h2 class="site-footer-col-heading">{{ ui.sitemap }}</h2>
        <ul class="site-footer-links">
          {% for item in footerNavItems %}
            <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="site-footer-col">
        <h2 class="site-footer-col-heading">{{ ui.tools }}</h2>
        <ul class="site-footer-links">
          {% for link in ui.links.tools %}
            <li>
              <a href="{{ link.url }}"{% if link.ext %} target="_blank" rel="noopener"{% endif %}>
                {{ link.label }}{% if link.ext %} <span aria-hidden="true" class="site-footer-ext">↗</span><span class="sr-only">{% if lang == "en" %}(opens in new tab){% elif lang == "sv" %}(öppnas i ny flik){% else %}(avautuu uudessa välilehdessä){% endif %}</span>{% endif %}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="site-footer-col">
        <h2 class="site-footer-col-heading">{{ ui.utility }}</h2>
        <ul class="site-footer-links">
          {% for link in ui.links.utility %}
            <li><a href="{{ link.url }}">{{ link.label }}</a></li>
          {% endfor %}
        </ul>
      </div>

    </div>

    <div class="site-footer-bottom">
      <p class="site-footer-copy">&copy; {{ ui.copy }}</p>
    </div>
  </div>
</footer>
