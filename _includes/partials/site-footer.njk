{% set ui = footerUi[localeCode] if footerUi[localeCode] else footerUi["fi"] %}

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-cols">

      <div class="site-footer-col">
        <h2 class="site-footer-col-heading">{{ ui.sitemap }}</h2>
        <ul class="site-footer-links">
          {% for link in ui.links.sitemap %}
            <li><a href="{{ link.url }}">{{ link.label }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="site-footer-col">
        <h2 class="site-footer-col-heading">{{ ui.tools }}</h2>
        <ul class="site-footer-links">
          {% for link in ui.links.tools %}
            <li>
              <a href="{{ link.url }}"{% if link.ext %} target="_blank" rel="noopener"{% endif %}>
                {{ link.label }}{% if link.ext %} <span aria-hidden="true" class="site-footer-ext">↗</span>{% endif %}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="site-footer-col">
        <h2 class="site-footer-col-heading">{{ ui.utility }}</h2>
        <ul class="site-footer-links">
          {% for link in ui.links.utility %}
            <li><a href="{{ link.url }}">{{ link.label }}</a></li>
          {% endfor %}
        </ul>
      </div>

    </div>

    <div class="site-footer-bottom">
      <p class="site-footer-copy">&copy; {{ ui.copy }}</p>
    </div>
  </div>
</footer>
