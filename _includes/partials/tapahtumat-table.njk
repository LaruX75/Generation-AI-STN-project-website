{% set allItems = tapahtumatItems or [] %}

{% if lang == "en" %}
  {% set lbl = {
    "heading": "Events", "search": "Search events", "placeholder": "Search by title…",
    "typeLabel": "Filter by type", "typeAll": "All types",
    "typeConf": "Conferences and seminars", "typeConfVal": "conferences and seminars",
    "typeWeb": "Webinar", "typeWebVal": "webinar",
    "typeWS": "Workshop", "typeWSVal": "workshop",
    "typeEvent": "Staff at events", "typeEventVal": "genai project staff at events",
    "badgeConf": "Conference", "badgeWeb": "Webinar", "badgeWS": "Workshop", "badgeEvent": "Event",
    "catConf": "Conferences and seminars", "catWeb": "Webinar", "catWS": "Workshop",
    "catEvent1": "GenAI project staff at events", "catEvent2": "GenAI Project Staff at Events",
    "yrLabel": "Filter by year", "yrAll": "All years",
    "aria": "Events", "ariaPag": "Result page",
    "colDate": "Date", "colType": "Type", "colTitle": "Title", "colDesc": "Description", "colLink": "Link",
    "open": "Open", "na": "Not available", "empty": "No results.",
    "prev": "← Previous", "next": "Next →",
    "jsPage": "Page", "jsSep": "/", "jsResults": "results"
  } %}
{% elif lang == "sv" %}
  {% set lbl = {
    "heading": "Evenemang", "search": "Sök evenemang", "placeholder": "Sök på rubrik…",
    "typeLabel": "Filtrera efter typ", "typeAll": "Alla typer",
    "typeConf": "Konferenser och seminarier", "typeConfVal": "konferenser och seminarier",
    "typeWeb": "Webbinarium", "typeWebVal": "webbinarium",
    "typeWS": "Workshop", "typeWSVal": "workshop",
    "typeEvent": "Personal vid evenemang", "typeEventVal": "genai-projektets personal vid evenemang",
    "badgeConf": "Konferens", "badgeWeb": "Webbinarium", "badgeWS": "Workshop", "badgeEvent": "Evenemang",
    "catConf": "Konferenser och seminarier", "catWeb": "Webbinarium", "catWS": "Workshop",
    "catEvent1": "GenAI-projektets personal vid evenemang", "catEvent2": "GenAI-projektets personal på evenemang",
    "yrLabel": "Filtrera efter år", "yrAll": "Alla år",
    "aria": "Evenemang", "ariaPag": "Resultatsida",
    "colDate": "Datum", "colType": "Typ", "colTitle": "Rubrik", "colDesc": "Beskrivning", "colLink": "Länk",
    "open": "Öppna", "na": "Ej tillgänglig", "empty": "Inga resultat.",
    "prev": "← Föregående", "next": "Nästa →",
    "jsPage": "Sida", "jsSep": "/", "jsResults": "resultat"
  } %}
{% else %}
  {% set lbl = {
    "heading": "Tapahtumat", "search": "Hae tapahtumista", "placeholder": "Hae otsikolla…",
    "typeLabel": "Suodata tyypeittäin", "typeAll": "Kaikki tyypit",
    "typeConf": "Konferenssit ja seminaarit", "typeConfVal": "konferenssit ja seminaarit",
    "typeWeb": "Webinaari", "typeWebVal": "webinaari",
    "typeWS": "Työpaja", "typeWSVal": "työpaja",
    "typeEvent": "Hankkeen henkilöstö tapahtumissa", "typeEventVal": "genai hankkeen henkilöstö tapahtumissa",
    "badgeConf": "Konferenssi", "badgeWeb": "Webinaari", "badgeWS": "Työpaja", "badgeEvent": "Tapahtuma",
    "catConf": "Konferenssit ja seminaarit", "catWeb": "Webinaari", "catWS": "Työpaja",
    "catEvent1": "GenAI hankkeen henkilöstö tapahtumissa", "catEvent2": "GenAI Hankkeen henkilöstö tapahtumissa",
    "yrLabel": "Suodata vuoden mukaan", "yrAll": "Kaikki vuodet",
    "aria": "Tapahtumat", "ariaPag": "Tulossivu",
    "colDate": "Päivämäärä", "colType": "Tyyppi", "colTitle": "Otsikko", "colDesc": "Kuvaus", "colLink": "Linkki",
    "open": "Avaa", "na": "Ei saatavilla", "empty": "Ei tuloksia.",
    "prev": "← Edellinen", "next": "Seuraava →",
    "jsPage": "Sivu", "jsSep": "/", "jsResults": "tulosta"
  } %}
{% endif %}

<section class="media-table-section" id="tapahtumat-table-section" data-grid-enhance>

  <div class="media-table-header">
    <h2 class="media-table-heading">{{ lbl.heading }}</h2>
    <div class="media-table-controls">
      <div class="media-table-search-wrap">
        <label for="tapahtumat-search" class="sr-only">{{ lbl.search }}</label>
        <input type="search" id="tapahtumat-search" class="media-table-search" placeholder="{{ lbl.placeholder }}" autocomplete="off" data-grid-search>
      </div>
      <div class="media-table-filters">
        <label for="tapahtumat-filter-type" class="sr-only">{{ lbl.typeLabel }}</label>
        <select id="tapahtumat-filter-type" class="media-table-filter" data-grid-filter="categories" data-grid-filter-mode="contains">
          <option value="">{{ lbl.typeAll }}</option>
          <option value="{{ lbl.typeConfVal }}">{{ lbl.typeConf }}</option>
          <option value="{{ lbl.typeWebVal }}">{{ lbl.typeWeb }}</option>
          <option value="{{ lbl.typeWSVal }}">{{ lbl.typeWS }}</option>
          <option value="{{ lbl.typeEventVal }}">{{ lbl.typeEvent }}</option>
        </select>
        <label for="tapahtumat-filter-year" class="sr-only">{{ lbl.yrLabel }}</label>
        <select id="tapahtumat-filter-year" class="media-table-filter" data-grid-filter="year" data-grid-populate-options="year">
          <option value="">{{ lbl.yrAll }}</option>
        </select>
      </div>
      <p class="media-table-count" id="tapahtumat-count" aria-live="polite" data-grid-count></p>
    </div>
  </div>

  <div class="media-table-wrap" role="region" aria-label="{{ lbl.aria }}">
    <table class="media-table" id="tapahtumat-table" data-grid-source>
      <thead>
        <tr>
          <th scope="col" class="media-table-col--date">{{ lbl.colDate }}</th>
          <th scope="col" class="media-table-col--source">{{ lbl.colType }}</th>
          <th scope="col" class="media-table-col--title">{{ lbl.colTitle }}</th>
          <th scope="col" class="media-table-col--content media-table-col--mobile-hide">{{ lbl.colDesc }}</th>
          <th scope="col" class="media-table-col--link media-table-col--mobile-hide">{{ lbl.colLink }}</th>
        </tr>
      </thead>
      <tbody id="tapahtumat-table-body">
        {% for post in allItems %}
          <tr class="media-table-row"
            data-year="{{ post.date | date('Y') }}"
            data-categories="{{ post.data.categories | join(',') | lower | default('') }}"
            data-search="{{ post.data.title | lower | default('') }}">
            <td class="media-table-col--date">
              <time datetime="{{ post.date | date('Y-m-d') }}">{{ post.date | date("d.m.Y") }}</time>
            </td>
            <td class="media-table-col--source">
              {% if post.data.categories %}
                {% for cat in post.data.categories %}
                  {% if cat == lbl.catConf %}
                    <span class="media-table-source-badge tapahtumat-badge--konferenssi">{{ lbl.badgeConf }}</span>
                  {% elif cat == lbl.catWeb %}
                    <span class="media-table-source-badge tapahtumat-badge--webinaari">{{ lbl.badgeWeb }}</span>
                  {% elif cat == lbl.catWS %}
                    <span class="media-table-source-badge tapahtumat-badge--tyopaja">{{ lbl.badgeWS }}</span>
                  {% elif cat == lbl.catEvent1 or cat == lbl.catEvent2 %}
                    <span class="media-table-source-badge tapahtumat-badge--tapahtuma">{{ lbl.badgeEvent }}</span>
                  {% endif %}
                {% endfor %}
              {% endif %}
            </td>
            <td class="media-table-col--title">
              {% if post.url %}
                <a href="{{ post.url }}" class="media-table-title-link">{{ post.data.title | default("—") }}</a>
              {% else %}
                {{ post.data.title | default("—") }}
              {% endif %}
            </td>
            <td class="media-table-col--content media-table-col--mobile-hide">
              {% if post.data.excerpt and post.data.excerpt != "[object Object]" %}
                {{ post.data.excerpt | truncate(200) }}
              {% else %}
                <span class="media-table-na">{{ lbl.na }}</span>
              {% endif %}
            </td>
            <td class="media-table-col--link media-table-col--mobile-hide">
              {% if post.url %}
                <a href="{{ post.url }}" class="media-table-link">{{ lbl.open }}&nbsp;↗</a>
              {% else %}
                <span class="media-table-na">—</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <p class="media-table-empty" id="tapahtumat-empty" hidden>{{ lbl.empty }}</p>
  </div>

  <nav class="media-table-pagination" id="tapahtumat-pagination" aria-label="{{ lbl.ariaPag }}">
    <button class="media-table-page-btn" id="tapahtumat-prev" aria-label="{{ lbl.prev }}">{{ lbl.prev }}</button>
    <span class="media-table-page-info" id="tapahtumat-page-info" aria-live="polite"></span>
    <button class="media-table-page-btn" id="tapahtumat-next" aria-label="{{ lbl.next }}">{{ lbl.next }}</button>
  </nav>

</section>
