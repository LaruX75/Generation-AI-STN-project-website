{% set allItems = scientificPublications.items or [] %}

{% if lang == "en" %}
  {% set lbl = {
    "heading": "Scientific publications",
    "search": "Search publications", "placeholder": "Search by title or author…",
    "catLabel": "Filter by publication type", "catAll": "All types",
    "catA": "A — Peer-reviewed articles", "catBE": "B/E — Books and edited volumes", "catOther": "Other",
    "yrLabel": "Filter by year", "yrAll": "All years",
    "aria": "Scientific publications", "ariaPag": "Result page",
    "colAuthors": "Authors", "colYear": "Year", "colTitle": "Title", "colVenue": "Publication", "colLink": "Link", "colCode": "Code",
    "open": "Open", "newTab": "(opens in new tab)", "na": "—", "empty": "No results.",
    "prev": "← Previous", "next": "Next →",
    "jsPage": "Page", "jsSep": "/", "jsResults": "results"
  } %}
{% elif lang == "sv" %}
  {% set lbl = {
    "heading": "Vetenskapliga publikationer",
    "search": "Sök publikationer", "placeholder": "Sök på rubrik eller författare…",
    "catLabel": "Filtrera efter publikationstyp", "catAll": "Alla typer",
    "catA": "A — Referentgranskade artiklar", "catBE": "B/E — Böcker och antologier", "catOther": "Övriga",
    "yrLabel": "Filtrera efter år", "yrAll": "Alla år",
    "aria": "Vetenskapliga publikationer", "ariaPag": "Resultatsida",
    "colAuthors": "Författare", "colYear": "År", "colTitle": "Titel", "colVenue": "Publikation", "colLink": "Länk", "colCode": "Kod",
    "open": "Öppna", "newTab": "(öppnas i ny flik)", "na": "—", "empty": "Inga resultat.",
    "prev": "← Föregående", "next": "Nästa →",
    "jsPage": "Sida", "jsSep": "/", "jsResults": "resultat"
  } %}
{% else %}
  {% set lbl = {
    "heading": "Tieteelliset julkaisut",
    "search": "Hae julkaisuista", "placeholder": "Hae otsikolla tai tekijällä…",
    "catLabel": "Suodata julkaisutyypin mukaan", "catAll": "Kaikki julkaisutyypit",
    "catA": "A — Vertaisarvioidut artikkelit", "catBE": "B/E — Kirjat ja kokoomateokset", "catOther": "Muut",
    "yrLabel": "Suodata vuoden mukaan", "yrAll": "Kaikki vuodet",
    "aria": "Tieteelliset julkaisut", "ariaPag": "Tulossivu",
    "colAuthors": "Tekijät", "colYear": "Vuosi", "colTitle": "Otsikko", "colVenue": "Julkaisun nimi", "colLink": "Linkki", "colCode": "Koodi",
    "open": "Avaa", "newTab": "(avautuu uudessa välilehdessä)", "na": "—", "empty": "Ei tuloksia.",
    "prev": "← Edellinen", "next": "Seuraava →",
    "jsPage": "Sivu", "jsSep": "/", "jsResults": "tulosta"
  } %}
{% endif %}

<section class="media-table-section" id="scipub-table-section">

  <div class="media-table-header">
    <h2 class="media-table-heading">{{ lbl.heading }}</h2>
    <div class="media-table-controls">
      <div class="media-table-search-wrap">
        <label for="scipub-search" class="sr-only">{{ lbl.search }}</label>
        <input type="search" id="scipub-search" class="media-table-search" placeholder="{{ lbl.placeholder }}" autocomplete="off">
      </div>
      <div class="media-table-filters">
        <label for="scipub-filter-cat" class="sr-only">{{ lbl.catLabel }}</label>
        <select id="scipub-filter-cat" class="media-table-filter">
          <option value="">{{ lbl.catAll }}</option>
          <option value="a">{{ lbl.catA }}</option>
          <option value="be">{{ lbl.catBE }}</option>
          <option value="other">{{ lbl.catOther }}</option>
        </select>
        <label for="scipub-filter-year" class="sr-only">{{ lbl.yrLabel }}</label>
        <select id="scipub-filter-year" class="media-table-filter">
          <option value="">{{ lbl.yrAll }}</option>
        </select>
      </div>
      <p class="media-table-count" id="scipub-count" aria-live="polite"></p>
    </div>
  </div>

  <div class="media-table-wrap" role="region" aria-label="{{ lbl.aria }}">
    <table class="media-table" id="scipub-table">
      <thead>
        <tr>
          <th scope="col" class="media-table-col--authors">{{ lbl.colAuthors }}</th>
          <th scope="col" class="media-table-col--date">{{ lbl.colYear }}</th>
          <th scope="col" class="media-table-col--title">{{ lbl.colTitle }}</th>
          <th scope="col" class="media-table-col--venue">{{ lbl.colVenue }}</th>
          <th scope="col" class="media-table-col--link">{{ lbl.colLink }}</th>
          <th scope="col" class="media-table-col--source">{{ lbl.colCode }}</th>
        </tr>
      </thead>
      <tbody id="scipub-table-body">
        {% for item in allItems %}
          <tr class="media-table-row"
            data-year="{{ item.year | default('') }}"
            data-category="{% if item.code and item.code | truncate(1, true, '') == 'A' %}a{% elif item.code and (item.code | truncate(1, true, '') == 'B' or item.code | truncate(1, true, '') == 'E') %}be{% else %}other{% endif %}"
            data-search="{{ item.searchText | lower | default('') }} {{ item.authorsText | lower | default('') }}">
            <td class="media-table-col--authors">{{ item.authorsText | default('—') }}</td>
            <td class="media-table-col--date">{{ item.year | default('—') }}</td>
            <td class="media-table-col--title">{{ item.title | default('—') }}</td>
            <td class="media-table-col--venue">{{ item.venue | default('—') }}</td>
            <td class="media-table-col--link">
              {% if item.link %}
                <a href="{{ item.link }}" class="media-table-link" target="_blank" rel="noopener noreferrer">{{ item.linkLabel | default(lbl.open) }}&nbsp;<span aria-hidden="true">↗</span><span class="sr-only">{{ lbl.newTab }}</span></a>
              {% else %}
                <span class="media-table-na">{{ lbl.na }}</span>
              {% endif %}
            </td>
            <td class="media-table-col--source">
              <span class="scipub-badge">{{ item.code | default('—') }}</span>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <p class="media-table-empty" id="scipub-empty" hidden>{{ lbl.empty }}</p>
  </div>

  <nav class="media-table-pagination" id="scipub-pagination" aria-label="{{ lbl.ariaPag }}">
    <button class="media-table-page-btn" id="scipub-prev" aria-label="{{ lbl.prev }}">{{ lbl.prev }}</button>
    <span class="media-table-page-info" id="scipub-page-info" aria-live="polite"></span>
    <button class="media-table-page-btn" id="scipub-next" aria-label="{{ lbl.next }}">{{ lbl.next }}</button>
  </nav>

</section>

<script>
(function () {
  var PAGE_SIZE = 10;
  var tbody    = document.getElementById('scipub-table-body');
  var emptyEl  = document.getElementById('scipub-empty');
  var searchEl = document.getElementById('scipub-search');
  var catEl    = document.getElementById('scipub-filter-cat');
  var yrEl     = document.getElementById('scipub-filter-year');
  var prevBtn  = document.getElementById('scipub-prev');
  var nextBtn  = document.getElementById('scipub-next');
  var pageInfo = document.getElementById('scipub-page-info');
  var countEl  = document.getElementById('scipub-count');
  if (!tbody) return;

  var allRows = Array.from(tbody.querySelectorAll('.media-table-row'));
  var filtered = allRows.slice();
  var currentPage = 1;

  (function () {
    var years = {};
    allRows.forEach(function (row) { var y = row.dataset.year; if (y) years[y] = true; });
    Object.keys(years).sort().reverse().forEach(function (yr) {
      var opt = document.createElement('option');
      opt.value = yr; opt.textContent = yr;
      yrEl.appendChild(opt);
    });
  }());

  function applyFilters() {
    var q   = searchEl.value.toLowerCase().trim();
    var cat = catEl.value;
    var yr  = yrEl.value;
    filtered = allRows.filter(function (row) {
      if (yr  && row.dataset.year !== yr) return false;
      if (cat && row.dataset.category !== cat) return false;
      if (q   && row.dataset.search.indexOf(q) === -1) return false;
      return true;
    });
  }

  function render() {
    applyFilters();
    var total = filtered.length;
    var totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;
    var start = (currentPage - 1) * PAGE_SIZE;
    allRows.forEach(function (row) { row.hidden = true; });
    filtered.slice(start, start + PAGE_SIZE).forEach(function (row) { row.hidden = false; });
    emptyEl.hidden = total > 0;
    prevBtn.disabled = currentPage <= 1;
    nextBtn.disabled = currentPage >= totalPages;
    pageInfo.textContent = '{{ lbl.jsPage }}\u00a0' + currentPage + '\u00a0{{ lbl.jsSep }}\u00a0' + totalPages;
    countEl.textContent  = total + '\u00a0{{ lbl.jsResults }}';
  }

  searchEl.addEventListener('input',  function () { currentPage = 1; render(); });
  catEl.addEventListener('change',    function () { currentPage = 1; render(); });
  yrEl.addEventListener('change',     function () { currentPage = 1; render(); });
  prevBtn.addEventListener('click',   function () { if (currentPage > 1) { currentPage--; render(); } });
  nextBtn.addEventListener('click',   function () {
    if (currentPage < Math.max(1, Math.ceil(filtered.length / PAGE_SIZE))) { currentPage++; render(); }
  });

  render();
}());
</script>
