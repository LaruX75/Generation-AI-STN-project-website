{% set allItems = institutionalVisibility.items or [] %}

<section class="media-table-section" id="iv-table-section" data-grid-enhance>

  <div class="media-table-header">
    <h2 class="media-table-heading">Yliopistojen omat sivut, uutiset ja tiedotteet</h2>
    <div class="media-table-controls">
      <div class="media-table-search-wrap">
        <label for="iv-search" class="sr-only">Hae julkaisuista</label>
        <input type="search" id="iv-search" class="media-table-search" placeholder="Hae otsikolla…" autocomplete="off" data-grid-search>
      </div>
      <div class="media-table-filters">
        <label for="iv-filter-year" class="sr-only">Suodata vuoden mukaan</label>
        <select id="iv-filter-year" class="media-table-filter" data-grid-filter="year" data-grid-populate-options="year">
          <option value="">Kaikki vuodet</option>
        </select>
      </div>
      <p class="media-table-count" id="iv-count" aria-live="polite" data-grid-count></p>
    </div>
  </div>

  <div class="media-table-wrap" role="region" aria-label="Yliopistojen omat sivut, uutiset ja tiedotteet">
    <table class="media-table" id="iv-table" data-grid-source>
      <thead>
        <tr>
          <th scope="col" class="media-table-col--date">Päivämäärä</th>
          <th scope="col" class="media-table-col--source">Lähde</th>
          <th scope="col" class="media-table-col--title">Otsikko</th>
          <th scope="col" class="media-table-col--people media-table-col--mobile-hide">Henkilöt</th>
        </tr>
      </thead>
      <tbody id="iv-table-body">
        {% for item in allItems %}
          <tr class="media-table-row"
            data-year="{{ item.sortDate | truncate(4, true, '') if item.sortDate else '' }}"
            data-search="{{ item.title | lower | default('') }} {{ item.sourceLabel | lower | default('') }}">
            <td class="media-table-col--date">{{ item.dateLabel | default('—') }}</td>
            <td class="media-table-col--source">
              <span class="iv-badge">{{ item.sourceLabel | default('—') }}</span>
              <span class="iv-type">{{ item.typeLabelFi | default('') }}</span>
            </td>
            <td class="media-table-col--title">
              <a href="{{ item.url }}" class="media-table-link" target="_blank" rel="noopener">{{ item.title | default('—') }}</a>
              {% if item.summary %}
                <div class="iv-summary">{{ item.summary }}</div>
              {% endif %}
            </td>
            <td class="media-table-col--people media-table-col--mobile-hide">{{ item.people | join(', ') }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <p class="media-table-empty" id="iv-empty" hidden>Ei tuloksia.</p>
  </div>

  <nav class="media-table-pagination" id="iv-pagination" aria-label="Tulossivu">
    <button class="media-table-page-btn" id="iv-prev" aria-label="Edellinen sivu">← Edellinen</button>
    <span class="media-table-page-info" id="iv-page-info" aria-live="polite"></span>
    <button class="media-table-page-btn" id="iv-next" aria-label="Seuraava sivu">Seuraava →</button>
  </nav>

</section>
