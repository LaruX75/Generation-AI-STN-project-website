{% set allItems = institutionalVisibility.items or [] %}

<section class="media-table-section" id="iv-table-section">

  <div class="media-table-header">
    <h2 class="media-table-heading">Yliopistojen omat sivut, uutiset ja tiedotteet</h2>
    <div class="media-table-controls">
      <div class="media-table-search-wrap">
        <label for="iv-search" class="sr-only">Hae julkaisuista</label>
        <input type="search" id="iv-search" class="media-table-search" placeholder="Hae otsikolla…" autocomplete="off">
      </div>
      <div class="media-table-filters">
        <label for="iv-filter-year" class="sr-only">Suodata vuoden mukaan</label>
        <select id="iv-filter-year" class="media-table-filter">
          <option value="">Kaikki vuodet</option>
        </select>
      </div>
      <p class="media-table-count" id="iv-count" aria-live="polite"></p>
    </div>
  </div>

  <div class="media-table-wrap" role="region" aria-label="Yliopistojen omat sivut, uutiset ja tiedotteet">
    <table class="media-table" id="iv-table">
      <thead>
        <tr>
          <th scope="col" class="media-table-col--date">Päivämäärä</th>
          <th scope="col" class="media-table-col--source">Lähde</th>
          <th scope="col" class="media-table-col--title">Otsikko</th>
          <th scope="col" class="media-table-col--people">Henkilöt</th>
        </tr>
      </thead>
      <tbody id="iv-table-body">
        {% for item in allItems %}
          <tr class="media-table-row"
            data-year="{{ item.sortDate | truncate(4, true, '') if item.sortDate else '' }}"
            data-search="{{ item.title | lower | default('') }} {{ item.sourceLabel | lower | default('') }}">
            <td class="media-table-col--date">{{ item.dateLabel | default('—') }}</td>
            <td class="media-table-col--source">
              <span class="iv-badge">{{ item.sourceLabel | default('—') }}</span>
              <span class="iv-type">{{ item.typeLabelFi | default('') }}</span>
            </td>
            <td class="media-table-col--title">
              <a href="{{ item.url }}" class="media-table-link" target="_blank" rel="noopener">{{ item.title | default('—') }}</a>
              {% if item.summary %}
                <div class="iv-summary">{{ item.summary }}</div>
              {% endif %}
            </td>
            <td class="media-table-col--people">{{ item.people | join(', ') }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <p class="media-table-empty" id="iv-empty" hidden>Ei tuloksia.</p>
  </div>

  <nav class="media-table-pagination" id="iv-pagination" aria-label="Tulossivu">
    <button class="media-table-page-btn" id="iv-prev" aria-label="Edellinen sivu">← Edellinen</button>
    <span class="media-table-page-info" id="iv-page-info" aria-live="polite"></span>
    <button class="media-table-page-btn" id="iv-next" aria-label="Seuraava sivu">Seuraava →</button>
  </nav>

</section>

<script>
(function () {
  var PAGE_SIZE = 10;
  var tbody    = document.getElementById('iv-table-body');
  var emptyEl  = document.getElementById('iv-empty');
  var searchEl = document.getElementById('iv-search');
  var yrEl     = document.getElementById('iv-filter-year');
  var prevBtn  = document.getElementById('iv-prev');
  var nextBtn  = document.getElementById('iv-next');
  var pageInfo = document.getElementById('iv-page-info');
  var countEl  = document.getElementById('iv-count');
  if (!tbody) return;

  var allRows = Array.from(tbody.querySelectorAll('.media-table-row'));
  var filtered = allRows.slice();
  var currentPage = 1;

  // Populate year filter dynamically from row data, sorted descending
  (function () {
    var years = {};
    allRows.forEach(function (row) { var y = row.dataset.year; if (y) years[y] = true; });
    Object.keys(years).sort().reverse().forEach(function (yr) {
      var opt = document.createElement('option');
      opt.value = yr; opt.textContent = yr;
      yrEl.appendChild(opt);
    });
  }());

  function applyFilters() {
    var q  = searchEl.value.toLowerCase().trim();
    var yr = yrEl.value;
    filtered = allRows.filter(function (row) {
      if (yr && row.dataset.year !== yr) return false;
      if (q  && row.dataset.search.indexOf(q) === -1) return false;
      return true;
    });
  }

  function render() {
    applyFilters();
    var total = filtered.length;
    var totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;
    var start = (currentPage - 1) * PAGE_SIZE;
    allRows.forEach(function (row) { row.hidden = true; });
    filtered.slice(start, start + PAGE_SIZE).forEach(function (row) { row.hidden = false; });
    emptyEl.hidden = total > 0;
    prevBtn.disabled = currentPage <= 1;
    nextBtn.disabled = currentPage >= totalPages;
    pageInfo.textContent = 'Sivu\u00a0' + currentPage + '\u00a0/\u00a0' + totalPages;
    countEl.textContent  = total + '\u00a0tulosta';
  }

  searchEl.addEventListener('input',  function () { currentPage = 1; render(); });
  yrEl.addEventListener('change',     function () { currentPage = 1; render(); });
  prevBtn.addEventListener('click',   function () { if (currentPage > 1) { currentPage--; render(); } });
  nextBtn.addEventListener('click',   function () {
    if (currentPage < Math.max(1, Math.ceil(filtered.length / PAGE_SIZE))) { currentPage++; render(); }
  });

  render();
}());
</script>
